{
  "SchemaVersion": 3,
  "Enabled": false,
  "TargetVersion": "1.6",
  "DimensionMultiple": 4,
  "TieRule": "Up",
  "PreserveAspectRatio": true,
  "PaddingMode": "Transparent",
  "CompressionFormat": "BC7_UNORM",
  "GenerateMipmaps": true,
  "KeepOriginalPng": true,
  "OverwriteExistingDds": true,
  "SkipExistingDds": true,
  "SkipUiTextures": false,
  "SkipNormalMaps": false,
  "ExcludedFolders": [
    ".git",
    ".github",
    ".vs",
    ".idea",
    "Source",
    "Sources",
    "Tests",
    "Test",
    "Docs",
    "Documentation",
    "obj",
    "bin",
    "Build",
    "Builds",
    "Cache",
    "Caches",
    "Output",
    "Logs",
    "Backups",
    "TextureWork"
  ],
  "UiPathPatterns": [
    "(?i)(^|[\\\\/])(UI|Interface|Widgets|Icons)([\\\\/]|$)"
  ],
  "NormalMapPatterns": [
    "(?i)(_n|_normal|normalmap)\\.png$"
  ],
  "ToolPath": "Tools\\DirectXTex\\texconv.exe",
  "WorkFolder": "TextureWork",
  "StagingFolder": "TextureWork\\Staging",
  "TemporaryFolder": "TextureWork\\Temp",
  "PlanFolder": "TextureWork\\Plans",
  "ManifestFolder": "TextureWork\\Manifests",
  "BackupFolder": "Backups\\Textures",
  "CacheFolder": "Cache\\Textures",
  "UseConversionCache": true,
  "SkipValidatedOutputs": true,
  "ValidateCachedOutputs": false,
  "DirectConvertValidDimensions": true,
  "TexconvBatchSize": 16,
  "InstallStrategy": "Move",
  "BackupStrategy": "Move",
  "PerformanceNotes": "Existing DDS files are header-scanned. Only DDS textures whose width or height is not divisible by DimensionMultiple are scheduled for repair. Existing DDS files are replaced without backup; PNG sources remain untouched.",
  "TexconvBatchTimeoutSeconds": 600,
  "ExistingDdsMode": "RepairInvalidDimensions",
  "BackupExistingDds": false,
  "RepairOnlyInvalidDimensions": true,
  "CorruptPngPolicy": "ReportOnly"
}