                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="INSTALLED" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/><TextBlock Text="{Binding Summary.ModCount}" FontSize="15" FontWeight="Bold" Margin="9,0,0,0" VerticalAlignment="Center"/></StackPanel>
                <Border Grid.Column="1" Width="1" Background="{DynamicResource Bg4Brush}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="MISSING" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/><TextBlock Text="{Binding Summary.MissingDependencies}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" Margin="9,0,0,0" VerticalAlignment="Center"/></StackPanel>
                <Border Grid.Column="3" Width="1" Background="{DynamicResource Bg4Brush}"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="CYCLES" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/><TextBlock Text="{Binding Summary.Cycles}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" Margin="9,0,0,0" VerticalAlignment="Center"/></StackPanel>
                <Border Grid.Column="5" Width="1" Background="{DynamicResource Bg4Brush}"/>
                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="METADATA" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/><TextBlock Text="{Binding Summary.MissingMetadata}" FontSize="15" FontWeight="Bold" Margin="9,0,0,0" VerticalAlignment="Center"/></StackPanel>
              </Grid>
            </Border>
            <Border Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="9" Margin="0,12,0,0" Padding="14">
