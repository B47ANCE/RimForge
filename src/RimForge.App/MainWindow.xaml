<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:forge="clr-namespace:RimForge.UI.Controls;assembly=RimForge.UI" xmlns:models="clr-namespace:RimForge.Core.Models;assembly=RimForge.Core" xmlns:inspector="clr-namespace:RimForge.App.Features.ModInspector" xmlns:sorter="clr-namespace:RimForge.App.Features.ModSorter" xmlns:issueviewer="clr-namespace:RimForge.App.Features.IssueViewer" xmlns:forgeview="clr-namespace:RimForge.App.Features.ForgeView" xmlns:console="clr-namespace:RimForge.App.Features.Console" xmlns:settings="clr-namespace:RimForge.App.Features.Settings" xmlns:commandbar="clr-namespace:RimForge.App.Features.CommandBar" xmlns:texturetools="clr-namespace:RimForge.App.Features.TextureTools" x:Class="RimForge.App.MainWindow" Title="RimForge" Icon="/RimForge.UI;component/Assets/Branding/Badge/RimForge.Badge.png" Width="1500" Height="920" MinWidth="1180" MinHeight="720" Background="{StaticResource Bg0Brush}" WindowStartupLocation="CenterScreen" ToolTipService.InitialShowDelay="75" ToolTipService.BetweenShowDelay="0" ToolTipService.ShowDuration="60000" PreviewKeyDown="MainWindow_PreviewKeyDown">
  <Window.Resources>
    <Style x:Key="ForgeEvidenceBadge" TargetType="Border">
      <Setter Property="Background" Value="#18242D35"/>
      <Setter Property="BorderBrush" Value="#46525D"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="5"/>
      <Setter Property="Padding" Value="6,2"/>
      <Setter Property="Margin" Value="3,0,0,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ModEvidenceKind.CSharp}">
          <Setter Property="Background" Value="#24345A"/>
          <Setter Property="BorderBrush" Value="#5B8CFF"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ModEvidenceKind.Harmony}">
          <Setter Property="Background" Value="#382750"/>
          <Setter Property="BorderBrush" Value="#A970FF"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ModEvidenceKind.Xml}">
          <Setter Property="Background" Value="#4A3020"/>
          <Setter Property="BorderBrush" Value="#F59E42"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ModEvidenceKind.PatchOperations}">
          <Setter Property="Background" Value="#173D3D"/>
          <Setter Property="BorderBrush" Value="#35C6BE"/>
        </DataTrigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ForgeEvidenceScrollBar" TargetType="ScrollBar">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Width" Value="12"/>
      <Setter Property="MinWidth" Value="12"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid Background="Transparent">
              <Track x:Name="PART_Track"
                     Orientation="{TemplateBinding Orientation}"
                     Minimum="{TemplateBinding Minimum}"
                     Maximum="{TemplateBinding Maximum}"
                     Value="{TemplateBinding Value}"
                     ViewportSize="{TemplateBinding ViewportSize}"
                     IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb MinHeight="34">
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbSurface" Background="{DynamicResource AccentBrush}" CornerRadius="5" Margin="3,2" Opacity="0.9"/>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbSurface" Property="Opacity" Value="1"/>
                          </Trigger>
                          <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbSurface" Property="Opacity" Value="1"/>
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False"/>
                </Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <DataTemplate x:Key="ForgeEvidenceBadgeTemplate">
      <Grid>
        <Border x:Name="BadgeHost"
                Style="{StaticResource ForgeEvidenceBadge}"
                Tag="{Binding ElementName=EvidencePopup}"
                MouseEnter="ForgeEvidenceBadge_MouseEnter"
                MouseLeave="ForgeEvidenceBadge_MouseLeave"
                MouseLeftButtonUp="ForgeEvidenceBadge_MouseLeftButtonUp">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding Label}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding CountText}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,0"/>
          </StackPanel>
        </Border>

        <Popup x:Name="EvidencePopup"
               PlacementTarget="{Binding ElementName=BadgeHost}"
               Placement="MousePoint"
               HorizontalOffset="12"
               VerticalOffset="12"
               AllowsTransparency="True"
               StaysOpen="True"
               PopupAnimation="Fade">
          <Border Tag="{Binding ElementName=EvidencePopup}"
                  Background="{DynamicResource Bg1Brush}"
                  BorderBrush="{DynamicResource AccentBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12"
                  Width="332"
                  MouseEnter="ForgeEvidencePopup_MouseEnter"
                  MouseLeave="ForgeEvidencePopup_MouseLeave">
            <Border.Effect>
              <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.42" Color="#FF000000"/>
            </Border.Effect>
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <Grid Grid.Row="0"
                    Tag="{Binding ElementName=EvidencePopup}"
                    Background="Transparent"
                    MouseLeftButtonDown="ForgeEvidencePopup_HeaderMouseLeftButtonDown"
                    MouseMove="ForgeEvidencePopup_HeaderMouseMove"
                    MouseLeftButtonUp="ForgeEvidencePopup_HeaderMouseLeftButtonUp">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="FORGE EVIDENCE" Foreground="{DynamicResource AccentBrush}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="PIN" FontSize="9" Padding="7,3" Margin="8,0,4,0"
                        Style="{StaticResource SecondaryButton}" Tag="{Binding ElementName=EvidencePopup}"
                        ToolTip="Pin this evidence card" Click="ForgeEvidencePopup_PinClick"/>
                <Button Grid.Column="2" Content="MOVE" FontSize="9" Padding="7,3" Margin="0,0,4,0"
                        Style="{StaticResource SecondaryButton}" Tag="{Binding ElementName=EvidencePopup}"
                        ToolTip="Pin and enable dragging by the header" Click="ForgeEvidencePopup_MoveClick"/>
                <Button Grid.Column="3" Content="×" FontSize="15" Padding="7,0"
                        Style="{StaticResource SecondaryButton}" Tag="{Binding ElementName=EvidencePopup}"
                        ToolTip="Close" Click="ForgeEvidencePopup_CloseClick"/>
              </Grid>

              <TextBlock Grid.Row="1" Text="{Binding Label}" FontSize="15" FontWeight="Bold" Margin="0,5,0,2"/>

              <StackPanel Grid.Row="2" Margin="0,5,0,2">
                <StackPanel.Style>
                  <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding HasTechnologyExplanation}" Value="False">
                        <Setter Property="Visibility" Value="Collapsed"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </StackPanel.Style>
                <TextBlock Text="WHAT THIS MEANS" Foreground="{DynamicResource AccentBrush}" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                <TextBlock Text="{Binding PlainLanguageExplanation}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
              </StackPanel>

              <StackPanel Grid.Row="3" Margin="0,7,0,2">
                <StackPanel.Style>
                  <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding HasTechnologyExplanation}" Value="False">
                        <Setter Property="Visibility" Value="Collapsed"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </StackPanel.Style>
                <TextBlock Text="WHY IT MATTERS" Foreground="{DynamicResource AccentBrush}" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                <TextBlock Text="{Binding WhyItMatters}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
              </StackPanel>

              <StackPanel Grid.Row="4" Margin="0,7,0,6">
                <TextBlock Text="WHY RIMFORGE TAGGED IT" Foreground="{DynamicResource AccentBrush}" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Details}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
              </StackPanel>

              <Grid Grid.Row="5">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Background="#24272C" BorderBrush="#66717D" BorderThickness="1" CornerRadius="5" MaxHeight="286">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Visible"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding FileList.Count}" Value="0"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled" Padding="8,6,2,6" PanningMode="VerticalOnly">
                    <ScrollViewer.Resources>
                      <Style TargetType="ScrollBar" BasedOn="{StaticResource ForgeEvidenceScrollBar}"/>
                    </ScrollViewer.Resources>
                    <ItemsControl ItemsSource="{Binding FileList}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding}" FontFamily="Cascadia Mono,Consolas" FontSize="9.5" TextWrapping="Wrap" Margin="0,2"/>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                  <Button Content="Copy file list" Style="{StaticResource SecondaryButton}" Padding="9,4"
                          Tag="{Binding ElementName=EvidencePopup}" Click="ForgeEvidencePopup_CopyFilesClick"/>
                </StackPanel>
              </Grid>
            </Grid>
          </Border>
        </Popup>
      </Grid>
    </DataTemplate>
  </Window.Resources>
  <Grid>
    <Grid Background="{StaticResource Bg2Brush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="360" x:Name="InspectorColumn"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="68"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="94"/>
      </Grid.RowDefinitions>
      <commandbar:EngineeringCommandBarView x:Name="EngineeringCommandBar" Grid.ColumnSpan="2" Panel.ZIndex="60"
