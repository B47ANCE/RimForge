                <UniformGrid Grid.Row="1" Columns="5">
                  <StackPanel Margin="8,0"><TextBlock Text="NODES" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/><TextBlock Text="{Binding GraphNodeCount}" Style="{StaticResource MetricValue}"/></StackPanel>
                  <StackPanel Margin="8,0"><TextBlock Text="RELATIONSHIPS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/><TextBlock Text="{Binding GraphEdgeCount}" Style="{StaticResource MetricValue}"/></StackPanel>
                  <StackPanel Margin="8,0"><TextBlock Text="CYCLES" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/><TextBlock Text="{Binding Summary.Cycles}" Style="{StaticResource MetricValue}" Foreground="{DynamicResource WarningBrush}"/></StackPanel>
                  <StackPanel Margin="8,0"><TextBlock Text="SEARCH MATCHES" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/><TextBlock Text="{Binding ForgeSearchMatchCount}" Style="{StaticResource MetricValue}" Foreground="{DynamicResource AccentBrush}"/></StackPanel>
                  <StackPanel Margin="8,0"><TextBlock Text="FOCUSED LINKS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/><TextBlock Text="{Binding ForgeFocusedRelationshipCount}" Style="{StaticResource MetricValue}" Foreground="{DynamicResource AccentBrush}"/></StackPanel>
                </UniformGrid>
              </Grid>
            </Border>
            <Border x:Name="TextureToolsPanel" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,12"
                    Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" MinHeight="620">
              <texturetools:TextureToolsView x:Name="TextureToolsFeature" ActivityRequested="TextureTools_ActivityRequested"/>
            </Border>
            <Border x:Name="SettingsPanel" Style="{StaticResource Card}" Padding="14" MinHeight="480" Margin="0,0,0,12"
                    Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1">
              <settings:SettingsView x:Name="SettingsFeature"
                                     SearchSteamLibrariesRequested="Settings_SearchSteamLibrariesRequested"
                                     SaveRequested="Settings_SaveRequested"
                                     ProfileCreateRequested="CreateProfile_Click"
                                     ProfileRenameRequested="RenameProfile_Click"
                                     ProfileOpenRequested="OpenOutput_Click"
                                     ProfileDuplicateRequested="DuplicateProfile_Click"
                                     ProfileFavoriteRequested="ToggleFavoriteProfile_Click"
                                     ProfileImportRequested="ImportProfile_Click"
                                     ProfileExportRequested="ExportProfile_Click"
                                     ProfileCompareRequested="CompareProfile_Click"
                                     ProfileLockRequested="ToggleProfileLock_Click"
                                     ProfileDeleteRequested="DeleteProfile_Click"/>
            </Border>
            <Grid x:Name="ConsolePanel" MinHeight="480" Margin="0">
              <console:ConsoleView x:Name="ConsoleFeature"
                                   StartWatchingRequested="Console_StartWatchingRequested"
                                   StopWatchingRequested="Console_StopWatchingRequested"
                                   ClearRequested="Console_ClearRequested"
                                   GameLogScrollChanged="Console_GameLogScrollChanged"/>
            </Grid>
          </StackPanel>
        </ScrollViewer>
</Grid>
      <inspector:ModInspectorView x:Name="ModInspectorControl"
                                  Grid.Row="0" Grid.RowSpan="4" Grid.Column="1"
                                  Margin="0,92,0,118" Panel.ZIndex="5"
                                  ToggleRequested="ToggleInspector_Click"
                                  OpenFolderRequested="OpenSelectedFolder_Click"
                                  OpenBrowserRequested="OpenSelectedSteamContentBrowser_Click"
                                  OpenSteamRequested="OpenSelectedSteamContentSteam_Click"
                                  RelatedModRequested="ModInspector_RelatedModRequested"
                                  SelectionBackRequested="SelectionBackRequested"
                                  SelectionForwardRequested="SelectionForwardRequested"/>
      <!-- Control Center communication surface. Background progress owns this row first;
           queued notifications appear here when the progress surface is released. -->
      <Border x:Name="ForgeNotificationBar" Grid.Row="2" Grid.ColumnSpan="2"
              Visibility="{Binding IsControlCenterNotificationVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="{DynamicResource Bg0Brush}" BorderBrush="{Binding ControlCenterNotificationBrush}"
              BorderThickness="0,1,0,1" Padding="14,8" Panel.ZIndex="48">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Border Background="{Binding ControlCenterNotificationBrush}" CornerRadius="2" Margin="0,0,10,0"/>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding CurrentNotification.Title}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding ControlCenterNotificationQueueText}" Margin="10,0,0,0"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <TextBlock Text="{Binding CurrentNotification.Message}" Margin="0,2,0,0" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
          <ItemsControl Grid.Column="2" ItemsSource="{Binding CurrentNotification.AvailableActions}"
                        VerticalAlignment="Center" Margin="12,0,0,0">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Content="{Binding Label}" CommandParameter="{Binding Id}"
                        Click="ControlCenterNotificationAction_Click"
                        Style="{DynamicResource SecondaryButton}" Padding="9,3" MinHeight="24" Margin="0,0,6,0"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Grid.Column="3" Content="×" Click="DismissControlCenterNotification_Click"
                  Background="Transparent" BorderThickness="0" Padding="8,2"
                  Foreground="{DynamicResource TextMutedBrush}" ToolTip="Dismiss notification"/>
        </Grid>
      </Border>

      <Border x:Name="GlobalFeatureTaskBar" Grid.Row="2" Grid.ColumnSpan="2"
              Visibility="{Binding IsGeneralFeatureTaskVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}"
              BorderThickness="0,1,0,0" Padding="14,8" Panel.ZIndex="48">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <StackPanel>
            <Grid Margin="0,0,12,0">
              <TextBlock Text="{Binding BackgroundTaskCurrentOperation}" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding BackgroundTaskCountText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                <TextBlock Text="{Binding BackgroundTaskElapsedText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="10,0,0,0"/>
              </StackPanel>
            </Grid>
            <TextBlock Text="{Binding BackgroundTaskTechnicalDetail}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,12,0"/>
            <TextBlock Text="{Binding BackgroundTaskDiscoveryDetail}" FontSize="10" Foreground="{DynamicResource InformationBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,12,0"/>
            <TextBlock Text="{Binding BackgroundTaskCurrentFile}" FontFamily="Cascadia Mono,Consolas" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,12,0"/>
            <ProgressBar Height="5" Margin="0,6,12,0" Minimum="0" Maximum="100"
                         Value="{Binding BackgroundTaskProgressValue, Mode=OneWay}"
                         IsIndeterminate="{Binding IsBackgroundTaskProgressIndeterminate}"/>
          </StackPanel>
          <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Cancel"
                  Click="Cancel_Click" MinWidth="88" VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <Border x:Name="NativeScanBar" Grid.Row="2" Grid.ColumnSpan="2"
              Visibility="{Binding IsNativeScanVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}"
              BorderThickness="0,1,0,0" Padding="14,8" Panel.ZIndex="49">
        <StackPanel>
          <Grid>
            <TextBlock Text="Preparing RimForge" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <TextBlock Text="{Binding NativeProgressValue, StringFormat={}{0}%}" VerticalAlignment="Center"
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock Text="{Binding BackgroundTaskCountText}" VerticalAlignment="Center"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="10,0,0,0"/>
              <TextBlock Text="{Binding BackgroundTaskElapsedText}" VerticalAlignment="Center"
                         FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="10,0,0,0"/>
              <Button Style="{StaticResource SecondaryButton}" Content="Cancel" Click="Cancel_Click"
                      MinWidth="76" Padding="8,2" Margin="10,0,0,0"/>
            </StackPanel>
          </Grid>
          <TextBlock Text="{Binding NativeProgressText}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
          <TextBlock Text="{Binding BackgroundTaskTechnicalDetail}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
          <TextBlock Text="{Binding BackgroundTaskDiscoveryDetail}" FontSize="10" Foreground="{DynamicResource InformationBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
          <TextBlock Text="{Binding BackgroundTaskCurrentFile}" FontFamily="Cascadia Mono,Consolas" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
          <ProgressBar Height="6" Margin="0,6,0,0" Minimum="0" Maximum="100" Value="{Binding NativeProgressValue, Mode=OneWay}"/>
        </StackPanel>
      </Border>

      <Border x:Name="GlobalForgeBar" Grid.Row="2" Grid.ColumnSpan="2"
              Visibility="{Binding IsForgeSessionVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}"
              BorderThickness="0,1,0,0" Padding="14,8" Panel.ZIndex="50">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel>
            <Grid>
              <StackPanel>
                <TextBlock Text="{Binding ForgeNarrativeText}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ForgeSession.Message}" FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding CompanionHostStatusText}" FontSize="10" Margin="0,2,0,0"
                           Foreground="{DynamicResource InformationBrush}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding RuntimeHealthText}" FontSize="10" Margin="0,2,0,0"
                           Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding ForgeAttentionMessage}" FontSize="11" Margin="0,2,0,0"
                           Foreground="{DynamicResource WarningBrush}" TextTrimming="CharacterEllipsis"
                           Visibility="{Binding IsForgeAttentionRequired, Converter={StaticResource BooleanToVisibilityConverter}}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding BackgroundTaskCountText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                <TextBlock Text="{Binding ForgeElapsedText}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="10,0,0,0"/>
              </StackPanel>
            </Grid>
            <TextBlock Text="{Binding BackgroundTaskTechnicalDetail}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
            <TextBlock Text="{Binding BackgroundTaskDiscoveryDetail}" FontSize="10" Foreground="{DynamicResource InformationBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
            <TextBlock Text="{Binding BackgroundTaskCurrentFile}" FontFamily="Cascadia Mono,Consolas" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
            <ProgressBar Height="6" Margin="0,6,0,0" Minimum="0" Maximum="100"
                         Value="{Binding ForgeSession.OverallProgress, Mode=OneWay}"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Visibility="{Binding IsForgeAttentionRequired, Converter={StaticResource BooleanToVisibilityConverter}}">
              <Button Style="{StaticResource PrimaryButton}" Content="Resolve Issue"
                      Click="ResolveForgeAttention_Click" Padding="12,6" Margin="0,0,8,0"
                      ToolTip="Open the current Forge finding in Issue Viewer, or open Console for a technical failure."/>
              <Button Style="{StaticResource SecondaryButton}" Content="Ignore for Now"
                      Click="IgnoreForgeAttention_Click" Padding="12,6"
                      ToolTip="Ignore the current finding and advance to the next Forge attention item."/>
            </StackPanel>
            <Button x:Name="LaunchForgedProfileButton" Style="{StaticResource PrimaryButton}"
                    Content="Launch Profile" Click="LaunchForgedProfile_Click" Visibility="Collapsed"
                    Margin="8,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </Border>

      <forge:ForgeLaunchBar x:Name="ControlCenter" Grid.Row="3" Grid.ColumnSpan="2" Panel.ZIndex="50"
                            RefreshRequested="RefreshLibrary_Click"
                            OpenProfileRequested="OpenOutput_Click"
                            LaunchRequested="LaunchProfile_Click"
                            ForgeRequested="RunAudit_Click"
                            ProfileManagementRequested="OpenProfileManagement_Click"
                            ProfileCreateRequested="CreateProfile_Click"
                            ProfileRenameRequested="RenameProfile_Click"
                            ProfileDuplicateRequested="DuplicateProfile_Click"
                            ProfileFavoriteRequested="ToggleFavoriteProfile_Click"
                            ProfileImportRequested="ImportProfile_Click"
                            ProfileExportRequested="ExportProfile_Click"
                            ProfileCompareRequested="CompareProfile_Click"
                            ProfileLockRequested="ToggleProfileLock_Click"
                            ProfileDeleteRequested="DeleteProfile_Click"
                            ManualAutoSortRequested="AutoSortLoadOrder_Click"
                            RevertChangesRequested="RevertLoadOrder_Click"
                            SaveLoadOrderRequested="SaveLoadOrder_Click"
                            ShowIssuesRequested="ShowProfileIssues_Click"
                            FixIssuesRequested="FixProfileIssues_Click"/>
    </Grid>

    <Grid Grid.ColumnSpan="2" Panel.ZIndex="500" Visibility="{Binding IsFirstRunGuideVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#D9000000">
      <Border Width="760" MaxHeight="700" HorizontalAlignment="Center" VerticalAlignment="Center"
              Background="{DynamicResource Bg1Brush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
              CornerRadius="14" Padding="28">
        <StackPanel>
          <TextBlock Text="WELCOME TO RIMFORGE" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold"/>
          <TextBlock Text="Your RimWorld mod engineering workspace" FontSize="26" FontWeight="Bold" Margin="0,6,0,10"/>
          <TextBlock Text="While you take a quick tour, RimForge is finding your RimWorld installation, installed DLC, local mods, and Steam Workshop library." TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>

          <UniformGrid Columns="3" Margin="0,24,0,22">
            <Border Background="{DynamicResource Bg2Brush}" CornerRadius="9" Padding="14" Margin="0,0,8,0">
              <StackPanel><TextBlock Text="1  PROFILES" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold"/><TextBlock Text="Profiles keep enabled mods, load order, analysis, and launch settings together." TextWrapping="Wrap" Margin="0,7,0,0"/></StackPanel>
            </Border>
            <Border Background="{DynamicResource Bg2Brush}" CornerRadius="9" Padding="14" Margin="4,0">
              <StackPanel><TextBlock Text="2  FORGE EVIDENCE" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold"/><TextBlock Text="Badges explain what a mod contains and why RimForge identified it." TextWrapping="Wrap" Margin="0,7,0,0"/></StackPanel>
            </Border>
            <Border Background="{DynamicResource Bg2Brush}" CornerRadius="9" Padding="14" Margin="8,0,0,0">
              <StackPanel><TextBlock Text="3  IGNITE THE FORGE" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold"/><TextBlock Text="Run a full audit to validate dependencies, metadata, compatibility, and evidence." TextWrapping="Wrap" Margin="0,7,0,0"/></StackPanel>
            </Border>
          </UniformGrid>

          <Border Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="9" Padding="14">
            <StackPanel>
              <Grid>
                <TextBlock FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="Preparing your library"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsNativeScanSuccessful}" Value="True">
                          <Setter Property="Text" Value="Scan Finished"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding NativeProgressValue, StringFormat={}{0}%}" HorizontalAlignment="Right" Foreground="{DynamicResource TextMutedBrush}"/>
              </Grid>
              <TextBlock Text="{Binding NativeProgressText}" Margin="0,3,0,7" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
              <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding NativeProgressValue, Mode=OneWay}"/>
            </StackPanel>
          </Border>

          <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Ignite the Forge" Width="260" Padding="24,12"
                    Click="IgniteFirstRunForge_Click">
              <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource IgniteForgeButton}">
                  <Setter Property="IsEnabled" Value="False"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsNativeScanSuccessful}" Value="True">
                      <Setter Property="IsEnabled" Value="True"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
            </Button>
            <Button Content="Skip this for now..." Click="SkipFirstRunGuide_Click"
                    HorizontalAlignment="Center" Margin="0,8,0,0" Padding="8,4"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource TextMutedBrush}" Cursor="Hand"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
