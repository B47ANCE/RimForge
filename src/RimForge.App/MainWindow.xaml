                                                   ForwardRequested="CommandBar_ForwardRequested"
                                                   UndoRequested="CommandBar_UndoRequested"
                                                   ReforgeRequested="CommandBar_ReforgeRequested"
                                                   NavigationRequested="CommandBar_NavigationRequested"
                                                   SearchResultInvoked="CommandBar_SearchResultInvoked"/>
      <Grid Grid.Row="0" Grid.RowSpan="4" Margin="24,0,12,0" Grid.Column="0" Panel.ZIndex="0">
        <ScrollViewer x:Name="WorkspaceScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False" ScrollChanged="WorkspaceScrollViewer_ScrollChanged" SizeChanged="WorkspaceScrollViewer_SizeChanged" PreviewMouseWheel="WorkspaceScrollViewer_PreviewMouseWheel" Margin="0">
          <StackPanel x:Name="WorkspaceSectionsPanel" Orientation="Vertical" Margin="0,92,0,118">
            <Border x:Name="DashboardPanel" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,12"
                    Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1">
              <StackPanel>
              <Grid x:Name="ModSorterWorkspacePanel" MinHeight="480" ClipToBounds="True">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="18" Visibility="Collapsed">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Border Background="{DynamicResource Bg1Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="9" Padding="14,10">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      <TextBlock Text="ACTIVE PROFILE" Style="{StaticResource InspectorSectionHeader}"/>
                      <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" Style="{StaticResource ProfileComboBox}" Margin="0,0,10,0">
                          <ComboBox.ItemTemplate>
                            <DataTemplate>
                              <Grid MinWidth="300">
                                <Grid.RowDefinitions>
                                  <RowDefinition Height="Auto"/>
                                  <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,3,0,0">
                                  <TextBlock Text="{Binding ModCount, StringFormat='{}{0} active mods'}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                  <TextBlock Text="  •  " FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                  <TextBlock Text="{Binding LockLabel}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                  <TextBlock Text="  •  Last generated " FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                  <TextBlock Text="{Binding LastGenerated, StringFormat='{}{0:g}', TargetNullValue='not yet'}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                              </Grid>
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Open Profile" Click="OpenOutput_Click" VerticalAlignment="Stretch"/>
                      </Grid>
                      <TextBlock Grid.Row="2" Text="{Binding SelectedProfile.ModCount, StringFormat='{}{0} active mods', TargetNullValue='Choose a profile workspace'}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="2,6,0,0"/>
                    </Grid>
                  </Border>
                  <Border Grid.Column="2" Grid.ColumnSpan="2" Background="{DynamicResource Bg1Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="9" Padding="14,10" Margin="0,0,0,0">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="PROFILE HEALTH" Style="{StaticResource InspectorSectionHeader}"/>
                        <TextBlock Text="{Binding ActiveProfileHealthText}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" Margin="0,5,0,2"/>
                        <TextBlock Text="{Binding ActiveProfileIssueSummary}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Content="Show Issues" Click="ShowProfileIssues_Click" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Fix Issues" Click="FixProfileIssues_Click"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Grid>
              </Border>
              <sorter:ModSorterView x:Name="ModSorterFeature"
                                    Grid.Row="0" Grid.RowSpan="3"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="0"
                                    ClipToBounds="True"
                                    SelectionRequested="ModSorter_SelectionRequested"
                                    DragStartRequested="ModSorter_DragStartRequested"
                                    DragMoveRequested="ModSorter_DragMoveRequested"
                                    ActiveDropRequested="ModSorter_ActiveDropRequested"
                                    InactiveDropRequested="ModSorter_InactiveDropRequested"
                                    SearchSteamLibrariesRequested="ModSorter_SearchSteamLibrariesRequested"
                                    OpenSettingsRequested="ModSorter_OpenSettingsRequested"
                                    HealthNavigationRequested="ModSorter_HealthNavigationRequested"/>
              <Border Grid.Row="2" Style="{StaticResource Card}" Visibility="Collapsed" Margin="0,0,0,12" Padding="18">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="FORGE SESSION" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                      <TextBlock Text="{Binding ForgeNarrativeText}" Style="{StaticResource ForgeNarrativeText}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding OverallProgressText}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Bottom"/>
                  </Grid>
                  <ProgressBar Grid.Row="1" Height="10" Margin="0,14,0,10" Minimum="0" Maximum="100" Value="{Binding OverallProgressValue, Mode=OneWay}"/>
                  <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="Technical task" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                      <TextBlock Text="{Binding ForgeTechnicalMessage}" FontWeight="SemiBold" Margin="0,3,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding PhaseProgressText}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Bottom"/>
                  </Grid>
                  <TextBlock Grid.Row="3" Margin="0,8,0,0" FontSize="11" Foreground="{DynamicResource InformationBrush}" Text="{Binding ForgePurposeText}" TextWrapping="Wrap"/>
                  <ProgressBar Grid.Row="4" Height="6" Margin="0,10,0,0" Minimum="0" Maximum="100" Value="{Binding PhaseProgressValue, Mode=OneWay}" IsIndeterminate="{Binding IsPhaseIndeterminate}"/>
                </Grid>
              </Border>
              <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0" Visibility="Collapsed">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <Grid Margin="0,0,0,12">
                    <TextBlock Text="Activity Feed" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Native engine and legacy audit stream" HorizontalAlignment="Right" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                  </Grid>
                  <ListBox Grid.Row="1" ItemsSource="{Binding ActivityEntries}" Style="{StaticResource ActivityFeedBox}" ItemContainerStyle="{StaticResource ActivityItemContainer}" ScrollViewer.VerticalScrollBarVisibility="Visible">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{StaticResource Bg1Brush}" CornerRadius="6" Padding="10,8">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="24"/>
                              <ColumnDefinition Width="66"/>
                              <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Symbol}" FontWeight="Bold" HorizontalAlignment="Center">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding Severity}" Value="Success">
                                      <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                      <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Severity}" Value="Error">
                                      <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="1" Text="{Binding TimeText}" Foreground="{StaticResource TextMutedBrush}" FontFamily="Cascadia Mono,Consolas" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap"/>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>
