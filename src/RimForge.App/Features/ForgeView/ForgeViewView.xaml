<UserControl x:Class="RimForge.App.Features.ForgeView.ForgeViewView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:local="clr-namespace:RimForge.App.Features.ForgeView">
  <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Grid Margin="18,16,18,10">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="ForgeView" FontSize="30" FontWeight="Bold"/>
          <TextBlock Text="Interactive dependency topology, synchronized outline, path focus, conflicts, and cycles."
                     Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
        </StackPanel>
        <Border Grid.Column="1" Background="{DynamicResource VisualSurfaceRaisedBrush}" BorderBrush="{DynamicResource VisualBorderBrush}"
                BorderThickness="1" CornerRadius="7" Padding="10,6" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,7,0"/>
            <TextBlock Text="Dependency workspace" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="1" Background="{DynamicResource VisualSurfaceRaisedBrush}" BorderBrush="{DynamicResource VisualBorderBrush}"
              BorderThickness="0,1,0,1" Padding="18,8">
        <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center">
          <Button x:Name="GraphModeButton" Style="{StaticResource VisualModeSelectorButton}" Content="Graph" Tag="Active" Click="GraphMode_Click" Margin="0,0,6,0"/>
          <Button x:Name="OutlineModeButton" Style="{StaticResource VisualModeSelectorButton}" Content="Outline" Click="OutlineMode_Click" Margin="0,0,14,0"/>
          <Button x:Name="PreviousSelectionButton" Style="{StaticResource SecondaryButton}" Content="←" ToolTip="Previous ForgeView selection" Click="PreviousSelection_Click" Width="38" IsEnabled="False" Margin="0,0,4,0"/>
          <Button x:Name="NextSelectionButton" Style="{StaticResource SecondaryButton}" Content="→" ToolTip="Next ForgeView selection" Click="NextSelection_Click" Width="38" IsEnabled="False" Margin="0,0,12,0"/>
          <Button Style="{StaticResource SecondaryButton}" Content="−" ToolTip="Zoom out" Click="ZoomOut_Click" Width="38"/>
          <TextBlock x:Name="ZoomText" Text="100%" Width="58" TextAlignment="Center" VerticalAlignment="Center"/>
          <Button Style="{StaticResource SecondaryButton}" Content="+" ToolTip="Zoom in" Click="ZoomIn_Click" Width="38" Margin="0,0,6,0"/>
          <Button Style="{StaticResource SecondaryButton}" Content="Fit" ToolTip="Fit the complete graph in the viewport (F)" Click="ResetView_Click" Margin="0,0,6,0"/>
          <Button Style="{StaticResource SecondaryButton}" Content="Center" ToolTip="Center the currently selected mod (Home)" Click="CenterSelection_Click" Margin="0,0,6,0"/>
          <Button x:Name="PathFocusButton" Style="{StaticResource SecondaryButton}" Content="Paths: On" ToolTip="Toggle upstream and downstream dependency-path emphasis" Click="PathFocus_Click" Margin="0,0,6,0"/>
          <Button x:Name="MinimapButton" Style="{StaticResource SecondaryButton}" Content="Minimap: On" ToolTip="Show or hide the clickable graph overview" Click="Minimap_Click" Margin="0,0,6,0"/>
          <ComboBox x:Name="HealthFilterCombo" Width="112" SelectedIndex="0" ToolTip="Filter graph nodes by current health" SelectionChanged="GraphFilter_SelectionChanged" Margin="0,0,6,0">
            <ComboBoxItem Content="All health" Tag="All"/>
            <ComboBoxItem Content="Healthy" Tag="Healthy"/>
            <ComboBoxItem Content="Warning" Tag="Warning"/>
            <ComboBoxItem Content="Error" Tag="Error"/>
            <ComboBoxItem Content="Unknown" Tag="Unknown"/>
            <ComboBoxItem Content="Updated" Tag="Updated"/>
          </ComboBox>
          <ComboBox x:Name="RelationshipFilterCombo" Width="126" SelectedIndex="0" ToolTip="Filter ForgeView relationship types" SelectionChanged="GraphFilter_SelectionChanged" Margin="0,0,6,0">
            <ComboBoxItem Content="All relationships" Tag="All"/>
            <ComboBoxItem Content="Required" Tag="Required"/>
            <ComboBoxItem Content="Optional" Tag="Optional"/>
            <ComboBoxItem Content="Ordering" Tag="Ordering"/>
            <ComboBoxItem Content="Conflicts" Tag="Conflicts"/>
          </ComboBox>
          <Button x:Name="IsolatePathButton" Style="{StaticResource SecondaryButton}" Content="Isolate Path: Off" ToolTip="Show only the selected mod and its reachable relationship path" Click="IsolatePath_Click" Margin="0,0,6,0"/>
          <Button x:Name="EditLayoutButton" Style="{StaticResource SecondaryButton}" Content="Edit Layout: Off" ToolTip="Enable profile-owned node movement" Click="EditLayout_Click" Margin="0,0,6,0"/>
          <Button x:Name="PinNodeButton" Style="{StaticResource SecondaryButton}" Content="Pin Node" ToolTip="Pin or unpin the selected node" Click="PinNode_Click" Margin="0,0,6,0"/>
          <Button Style="{StaticResource SecondaryButton}" Content="Reset Layout" ToolTip="Restore the deterministic Forged Layout" Click="ResetLayout_Click" Margin="0,0,6,0"/>
          <Button Style="{StaticResource SecondaryButton}" Content="Export" Click="Export_Click" Margin="0,0,6,0"/>
          <Button Style="{StaticResource SecondaryButton}" Content="Refresh" Click="Refresh_Click"/>
        </WrapPanel>
      </Border>

      <Grid Grid.Row="2" Margin="18,16,18,12">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Padding="0" ClipToBounds="True" Background="{DynamicResource Bg0Brush}"
                BorderBrush="{DynamicResource VisualBorderBrush}" BorderThickness="1" CornerRadius="9">
          <Grid x:Name="GraphViewport">
            <local:ForgeGraphCanvas x:Name="GraphCanvas"
               Nodes="{Binding DependencyNodes}"
               Edges="{Binding DependencyEdges}"
               SelectedPackageId="{Binding SelectedMod.PackageId}"
               SearchText="{Binding SearchText}"
               SearchMatchPackageIds="{Binding SearchMatchedPackageIds}"
               ProfilePackageIds="{Binding SelectedProfile.ActiveMods}"
               ShowFullLibrary="{Binding ShowFullLibrary}"
               HighlightDependencyPaths="True"
               ShowMinimap="True"
               IsLayoutEditMode="False"
               HealthFilter="All"
               RelationshipFilter="All"
               IsolateFocusedPath="False"
               NodeInvoked="GraphCanvas_NodeInvoked"
               NodeHoverChanged="GraphCanvas_NodeHoverChanged"
               RenderCompleted="GraphCanvas_RenderCompleted"
               LayoutChanged="GraphCanvas_LayoutChanged"
               ViewChanged="GraphCanvas_ViewChanged"/>
            <ScrollViewer x:Name="OutlineScroller" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="12" HorizontalContentAlignment="Left">
              <ItemsControl x:Name="OutlineItems" HorizontalAlignment="Left" HorizontalContentAlignment="Left"/>
            </ScrollViewer>
            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Padding="10,6" CornerRadius="6" Background="{DynamicResource VisualSurfaceRaisedBrush}" BorderBrush="{DynamicResource VisualBorderBrush}" BorderThickness="1">
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="FilterStatusText" Text="All graph evidence" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock Text="Drag to pan • Wheel to zoom • Filters preserve the evidence model • Edit Layout enables node movement" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,0" Background="{StaticResource Bg1Brush}" Padding="18" CornerRadius="9"
                BorderBrush="{DynamicResource VisualBorderBrush}" BorderThickness="1">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="SELECTION CONTEXT" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
              <TextBlock Text="{Binding ForgeFocusDisplayName}" FontSize="19" FontWeight="SemiBold" Margin="0,8,0,3" TextWrapping="Wrap"/>
              <TextBlock Text="{Binding ForgeFocusPackageId}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
              <TextBlock Text="{Binding ForgeFocusSummary}" Margin="0,10,0,0" TextWrapping="Wrap"/>
              <TextBlock Text="RELATIONSHIP PROVENANCE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,12,0,4"/>
              <TextBlock Text="{Binding ForgeFocusedProvenanceSummary}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
              <TextBlock Text="{Binding SelectionBreadcrumb}" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
              <TextBlock Text="{Binding ForgeInteractionStatus}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
              <TextBlock Text="{Binding ForgeHoverSummary}" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="DEPENDENCY HEALTH" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
              <TextBlock Text="{Binding DependencyManagementHealthText}" TextWrapping="Wrap" Margin="0,6,0,4"/>
              <TextBlock Text="{Binding DependencyManagementCountsText}" Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap"/>
              <TextBlock Text="RELATIONSHIP LEGEND" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,12,0,5"/>
              <TextBlock FontSize="10" TextWrapping="Wrap" Margin="0,0,0,5">
                <Run Text="Selected perspective: "/><Run Text="orange = selected requires target" Foreground="#FFF28C28"/><Run Text=" • "/><Run Text="cyan = source requires selected" Foreground="#FF3EC6D6"/>
              </TextBlock>
              <Grid Margin="0,2">
                <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Line X1="2" X2="44" Y1="5" Y2="5" Stroke="#FFA6ABB5" StrokeThickness="2"/>
                <TextBlock Grid.Column="1" Text="Required — solid, arrow points to dependency" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
              </Grid>
              <Grid Margin="0,2">
                <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Line X1="2" X2="44" Y1="5" Y2="5" Stroke="#FF4DA3FF" StrokeThickness="2" StrokeDashArray="8 4"/>
                <TextBlock Grid.Column="1" Text="Optional — long dash" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
              </Grid>
              <Grid Margin="0,2">
                <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Line X1="2" X2="44" Y1="5" Y2="5" Stroke="#FFCA97FF" StrokeThickness="2" StrokeDashArray="8 3 1 3"/>
                <TextBlock Grid.Column="1" Text="Load order — dash-dot, arrow shows order" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
              </Grid>
              <Grid Margin="0,2">
                <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Line X1="2" X2="44" Y1="5" Y2="5" Stroke="#FF6ECD92" StrokeThickness="2" StrokeDashArray="1 2"/>
                <TextBlock Grid.Column="1" Text="Patch target — dotted" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
              </Grid>
              <Grid Margin="0,2">
                <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Line X1="2" X2="44" Y1="5" Y2="5" Stroke="#FFE64C4C" StrokeThickness="2" StrokeDashArray="2 2.4"/>
                <TextBlock Grid.Column="1" Text="Incompatible — red short dash, bidirectional" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
              </Grid>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Row="3" Background="{DynamicResource VisualSurfaceRaisedBrush}" BorderBrush="{DynamicResource VisualBorderBrush}"
              BorderThickness="0,1,0,0" Padding="18,8">
        <Grid>
          <TextBlock Text="Minimap: click or drag to focus" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
          <TextBlock Text="{Binding ForgeGraphRenderStatus}" HorizontalAlignment="Right"
                     Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
