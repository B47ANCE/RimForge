<UserControl x:Class="RimForge.App.Features.TextureTools.TextureToolsView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <Grid Margin="4,2,4,14">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel><TextBlock Text="Texture Conversion Tools" FontSize="30" FontWeight="Bold"/><TextBlock Text="Analyze the active profile once, then convert eligible textures without modifying source files." Foreground="{DynamicResource TextMutedBrush}" Margin="0,5,0,0"/></StackPanel>
      <Border Grid.Column="1" Background="{DynamicResource Bg1Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="7" Padding="10,6" VerticalAlignment="Center"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,7,0"/><TextBlock Text="{Binding EngineStatus, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/></StackPanel></Border>
    </Grid>
    <Border Grid.Row="1" Background="{DynamicResource Bg1Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,0,0,12">
      <WrapPanel>
        <Button x:Name="AnalyzeProfileButton" Style="{StaticResource SecondaryButton}" Content="{Binding AnalyzeButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}" Click="AnalyzeProfile_Click" IsEnabled="{Binding CanRunTools, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="0,0,8,0"/>
        <Button Style="{StaticResource SecondaryButton}" Content="Revert Conversion" Click="RevertConversion_Click" IsEnabled="{Binding CanRunTools, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="0,0,18,0"/>
        <TextBlock Text="Preset" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,8,0"/>
        <ComboBox x:Name="PresetCombo" Width="190" SelectedIndex="0" SelectionChanged="PresetCombo_SelectionChanged"><ComboBoxItem Content="RimWorld Safe / Balanced"/><ComboBoxItem Content="Performance / BC1"/><ComboBoxItem Content="Quality / Preserve Alpha"/></ComboBox>
      </WrapPanel>
    </Border>
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="0.75*"/></Grid.ColumnDefinitions>
      <Border Background="{DynamicResource Bg1Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="9" Padding="14">
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="ACTIVE PROFILE TEXTURES" Style="{StaticResource InspectorSectionHeader}"/><TextBlock Text="Analysis results and DDS conversion candidates" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,3,0,10"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding QueueSummary, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/></Grid>
          <Grid Grid.Row="1">
            <ListView x:Name="QueueList" SelectionMode="Extended" ItemsSource="{Binding Queue, RelativeSource={RelativeSource AncestorType=UserControl}}" Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto">
              <ListView.View><GridView><GridViewColumn Header="Texture" Width="280" DisplayMemberBinding="{Binding RelativePath}"/><GridViewColumn Header="Size" Width="80" DisplayMemberBinding="{Binding SourceSize}"/><GridViewColumn Header="State" Width="95" DisplayMemberBinding="{Binding StateText}"/><GridViewColumn Header="Details" Width="250" DisplayMemberBinding="{Binding Status}"/></GridView></ListView.View>
            </ListView>
            <StackPanel x:Name="EmptyQueuePanel" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="No profile analysis yet" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Analyze the active profile to discover its textures." Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0" TextAlignment="Center"/></StackPanel>
          </Grid>
        </Grid>
      </Border>
      <Border Grid.Column="2" Background="{DynamicResource Bg1Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="9" Padding="14">
        <StackPanel>
          <TextBlock Text="CONVERSION SETTINGS" Style="{StaticResource InspectorSectionHeader}"/>
          <TextBlock Text="Target format" Style="{StaticResource InspectorLabel}" Margin="0,8,0,4"/>
          <ComboBox x:Name="FormatCombo" SelectedIndex="4"><ComboBoxItem Content="PNG (lossless)"/><ComboBoxItem Content="JPEG (quality 92)"/><ComboBoxItem Content="BMP"/><ComboBoxItem Content="TIFF (ZIP)"/><ComboBoxItem Content="DDS (BC7)"/><ComboBoxItem Content="DDS (BC3 / DXT5 compatibility)"/><ComboBoxItem Content="DDS (BC1 / DXT1 performance)"/></ComboBox>
          <TextBlock Text="Maximum texture size" Style="{StaticResource InspectorLabel}" Margin="0,14,0,4"/>
          <ComboBox x:Name="SizeCombo" SelectedIndex="1"><ComboBoxItem Content="1024"/><ComboBoxItem Content="2048"/><ComboBoxItem Content="4096"/></ComboBox>
          <CheckBox x:Name="PreserveAlphaCheck" Content="Preserve alpha channels" IsChecked="True" Margin="0,14,0,6"/>
          <CheckBox x:Name="SkipUnchangedCheck" Content="Skip unchanged conversions" IsChecked="True"/>
          <TextBlock Text="Output folder" Style="{StaticResource InspectorLabel}" Margin="0,14,0,4"/>
          <DockPanel><Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" Content="Browse" Click="BrowseOutput_Click" Margin="6,0,0,0"/><TextBox x:Name="OutputPathText" Text="{Binding DefaultOutputPath, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}" IsReadOnly="True"/></DockPanel>
          <TextBlock Text="DDS dimensions are normalized to the nearest multiple of 4 before DirectXTex conversion. Source files are never modified." Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>
          <Separator Margin="0,16,0,14"/><TextBlock Text="Estimated source size" Foreground="{DynamicResource TextMutedBrush}"/><TextBlock Text="{Binding SourceSizeSummary, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="26" FontWeight="SemiBold" Margin="0,3,0,0"/>
        </StackPanel>
      </Border>
    </Grid>
    <Border Grid.Row="3" Background="{DynamicResource Bg1Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,12,0,0">
      <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <StackPanel>
          <Grid Margin="0,0,20,0"><TextBlock Text="{Binding StatusTitle, RelativeSource={RelativeSource AncestorType=UserControl}}" FontWeight="SemiBold"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><TextBlock Text="{Binding BackgroundTaskCountText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/><TextBlock Text="{Binding BackgroundTaskElapsedText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="10,0,0,0"/></StackPanel></Grid>
          <TextBlock Text="{Binding StatusDetail, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,3,20,0" TextTrimming="CharacterEllipsis"/>
          <TextBlock Text="{Binding BackgroundTaskDiscoveryDetail, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource InformationBrush}" FontSize="10" Margin="0,2,20,0" TextTrimming="CharacterEllipsis"/>
          <TextBlock Text="{Binding BackgroundTaskCurrentFile, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource TextMutedBrush}" FontFamily="Cascadia Mono,Consolas" FontSize="9" Margin="0,2,20,0" TextTrimming="CharacterEllipsis"/>
          <ProgressBar Height="5" Margin="0,8,20,0" Minimum="0" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Cancel" Click="Cancel_Click" IsEnabled="{Binding IsConverting, RelativeSource={RelativeSource AncestorType=UserControl}}" MinWidth="90" Margin="0,0,8,0"/>
        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Convert Selected" Click="ConvertSelected_Click" IsEnabled="{Binding CanConvert, RelativeSource={RelativeSource AncestorType=UserControl}}" MinWidth="130" Margin="0,0,8,0"/>
        <Button Grid.Column="3" Style="{StaticResource PrimaryButton}" Content="Convert All Eligible" Click="ConvertAll_Click" IsEnabled="{Binding CanConvert, RelativeSource={RelativeSource AncestorType=UserControl}}" MinWidth="155"/>
      </Grid>
    </Border>
  </Grid>
</UserControl>
