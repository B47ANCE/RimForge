<UserControl x:Class="RimForge.App.Features.ModSorter.ModSorterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             MinHeight="0"
             ClipToBounds="True">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
  </UserControl.Resources>
  <Grid x:Name="ModSorterViewportRoot" MinHeight="0" ClipToBounds="True">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid x:Name="ModListsViewport" Grid.Row="0" VerticalAlignment="Stretch" MinHeight="0" ClipToBounds="True">
      <Grid.ColumnDefinitions><ColumnDefinition Width="1*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
      <Border Grid.Column="0" Style="{StaticResource DashboardListCard}" Padding="12" ClipToBounds="True" VerticalAlignment="Stretch" MinHeight="0">
        <Grid MinHeight="0" ClipToBounds="True">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Grid Margin="0,0,0,8"><TextBlock Text="INACTIVE INSTALLED MODS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/><TextBlock Text="{Binding InactiveInstalledCountText}" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/></Grid>
          <Border Grid.Row="1" MinHeight="0" Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="9" ClipToBounds="True" Padding="4">
            <ListBox x:Name="InactiveModsList" SelectionMode="Extended" ItemsSource="{Binding InactiveInstalledModsView}" SelectionChanged="List_SelectionChanged" AllowDrop="True" Drop="Inactive_Drop" PreviewDragOver="List_PreviewDragOver" DragLeave="List_DragLeave" GiveFeedback="List_GiveFeedback" QueryContinueDrag="List_QueryContinueDrag" PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown" PreviewMouseMove="List_PreviewMouseMove" VerticalAlignment="Stretch" MinHeight="0" ScrollViewer.VerticalScrollBarVisibility="Visible" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
              <ListBox.Resources><Style TargetType="ScrollBar" BasedOn="{StaticResource PersistentForgeScrollBarStyle}"/></ListBox.Resources>
              <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0,0,0,3"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style></ListBox.ItemContainerStyle>
              <ListBox.ItemTemplate><DataTemplate><Border CornerRadius="6" Padding="7,3"><Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource Bg2Brush}"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsSearchActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/><Setter Property="BorderThickness" Value="1"/></DataTrigger><DataTrigger Binding="{Binding IsDragGhost}" Value="True"><Setter Property="Opacity" Value="0.28"/><Setter Property="Background" Value="{DynamicResource Bg1Brush}"/></DataTrigger></Style.Triggers></Style></Border.Style><Grid ToolTip="{Binding PackageId}"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Path Grid.Column="0" Data="{Binding SourceIconGeometry}" Fill="White" Stretch="Uniform" Width="18" Height="18" Margin="0,0,7,0" ToolTip="{Binding SourceToolTip}" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0" ToolTipService.ShowDuration="60000"/><Button Grid.Column="1" Click="HealthAnvil_Click" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,7,0" Cursor="Hand" ToolTip="{Binding HealthToolTip}" Visibility="{Binding ShowHealthIndicator, Converter={StaticResource BooleanToVisibilityConverter}}"><ContentControl Style="{StaticResource ForgeDiagnosticAnvil}" Tag="{Binding HealthState}" IsHitTestVisible="False"/></Button><TextBlock Grid.Column="2" Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/><StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding ShowEvidenceBadges, Converter={StaticResource BooleanToVisibilityConverter}}"><ItemsControl ItemsSource="{Binding VisibleEvidenceBadges}" ItemTemplate="{DynamicResource ForgeEvidenceBadgeTemplate}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl><Border Style="{DynamicResource ForgeEvidenceBadge}" Visibility="{Binding HasHiddenEvidenceBadges, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="{Binding EvidenceDnaText}"><TextBlock Text="{Binding HiddenEvidenceBadgeText}" FontSize="9" FontWeight="SemiBold"/></Border></StackPanel></Grid></Border></DataTemplate></ListBox.ItemTemplate>
            </ListBox>
          </Border>
        </Grid>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource DashboardListCard}" Padding="12" ClipToBounds="True" VerticalAlignment="Stretch" MinHeight="0">
        <Grid MinHeight="0" ClipToBounds="True">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Grid Margin="0,0,0,8"><StackPanel Orientation="Horizontal"><TextBlock Text="ACTIVE PROFILE LOAD ORDER" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/><TextBlock Text="{Binding ActiveProfileCountText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/></StackPanel></Grid>
          <Border Grid.Row="1" MinHeight="0" Background="{DynamicResource Bg0Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="9" ClipToBounds="True" Padding="4">
            <ListBox x:Name="ActiveModsList" SelectionMode="Extended" ItemsSource="{Binding ActiveProfileModsView}" SelectedItem="{Binding SelectedLoadOrderItem}" SelectionChanged="List_SelectionChanged" AllowDrop="True" Drop="Active_Drop" PreviewDragOver="List_PreviewDragOver" DragLeave="List_DragLeave" GiveFeedback="List_GiveFeedback" QueryContinueDrag="List_QueryContinueDrag" PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown" PreviewMouseMove="List_PreviewMouseMove" VerticalAlignment="Stretch" MinHeight="0" ScrollViewer.VerticalScrollBarVisibility="Visible" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
              <ListBox.Resources><Style TargetType="ScrollBar" BasedOn="{StaticResource PersistentForgeScrollBarStyle}"/></ListBox.Resources>
              <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0,0,0,3"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style></ListBox.ItemContainerStyle>
              <ListBox.ItemTemplate><DataTemplate><Border CornerRadius="6" Padding="7,3"><Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource Bg2Brush}"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsSearchActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/><Setter Property="BorderThickness" Value="1"/></DataTrigger><DataTrigger Binding="{Binding IsDragGhost}" Value="True"><Setter Property="Opacity" Value="0.28"/><Setter Property="Background" Value="{DynamicResource Bg1Brush}"/></DataTrigger></Style.Triggers></Style></Border.Style><Grid ToolTip="{Binding PackageId}"><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding PositionText}" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/><Path Grid.Column="1" Data="{Binding SourceIconGeometry}" Fill="White" Stretch="Uniform" Width="18" Height="18" Margin="0,0,7,0" ToolTip="{Binding SourceToolTip}" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0" ToolTipService.ShowDuration="60000"/><Button Grid.Column="2" Click="HealthAnvil_Click" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,7,0" Cursor="Hand" ToolTip="{Binding HealthToolTip}" Visibility="{Binding ShowHealthIndicator, Converter={StaticResource BooleanToVisibilityConverter}}"><ContentControl Style="{StaticResource ForgeDiagnosticAnvil}" Tag="{Binding HealthState}" IsHitTestVisible="False"/></Button><TextBlock Grid.Column="3" Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/><StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding ShowEvidenceBadges, Converter={StaticResource BooleanToVisibilityConverter}}"><ItemsControl ItemsSource="{Binding VisibleEvidenceBadges}" ItemTemplate="{DynamicResource ForgeEvidenceBadgeTemplate}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl><Border Style="{DynamicResource ForgeEvidenceBadge}" Visibility="{Binding HasHiddenEvidenceBadges, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="{Binding EvidenceDnaText}"><TextBlock Text="{Binding HiddenEvidenceBadgeText}" FontSize="9" FontWeight="SemiBold"/></Border></StackPanel></Grid></Border></DataTemplate></ListBox.ItemTemplate>
            </ListBox>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <Border x:Name="LibraryEmptyState" Grid.Row="1" Visibility="Collapsed" Background="{DynamicResource Bg1Brush}" BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" CornerRadius="8" Padding="28" Margin="0,12,0,0">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520"><TextBlock Text="No RimWorld mods were found" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="RimForge could not find a valid Workshop or local Mods folder. Search your Steam libraries automatically or choose the folders in Settings." TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,18"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><Button Style="{StaticResource PrimaryButton}" Content="Search Steam Libraries" Click="SearchSteamLibraries_Click" Margin="0,0,10,0"/><Button Style="{StaticResource SecondaryButton}" Content="Open Settings" Click="OpenSettings_Click"/></StackPanel></StackPanel>
    </Border>
  </Grid>
</UserControl>
