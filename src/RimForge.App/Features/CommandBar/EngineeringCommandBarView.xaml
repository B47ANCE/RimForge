<UserControl x:Class="RimForge.App.Features.CommandBar.EngineeringCommandBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:search="clr-namespace:RimForge.App.Features.Search"
             x:Name="Root"
             MinHeight="64">
  <Border Background="{DynamicResource WorkstationChromeBackgroundBrush}"
          BorderBrush="{DynamicResource WorkstationChromeBorderBrush}"
          BorderThickness="0,0,0,1"
          Padding="14,9">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <!-- Left-side actions are deliberately independent from the centered search host. -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Panel.ZIndex="110">
        <Border Background="{DynamicResource WorkstationChromeRaisedBrush}"
                BorderBrush="{DynamicResource WorkstationChromeQuietBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="3">
          <Button x:Name="NavigationMenuButton" Style="{StaticResource WorkstationChromeButton}" Click="NavigationMenu_Click"
                  ToolTip="Open RimForge navigation" AutomationProperties.Name="Navigation menu">
            <TextBlock Style="{StaticResource WorkstationChromeGlyph}" Text="&#xE700;"/>
          </Button>
        </Border>

        <Border Style="{StaticResource WorkstationChromeSeparator}"/>

        <!-- Preserve the approved Back/Forward presentation exactly as one paired control. -->
        <Border Background="{DynamicResource WorkstationChromeRaisedBrush}"
                BorderBrush="{DynamicResource WorkstationChromeQuietBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="3">
          <StackPanel Orientation="Horizontal">
            <Button Style="{StaticResource WorkstationChromeButton}" IsEnabled="{Binding CanNavigateBack}" Click="Back_Click"
                    ToolTip="Back — restore the previous workstation context (Ctrl+Left)" AutomationProperties.Name="Back">
              <TextBlock Style="{StaticResource WorkstationChromeGlyph}" Text="&#xE72B;"/>
            </Button>
            <Button Style="{StaticResource WorkstationChromeButton}" IsEnabled="{Binding CanNavigateForward}" Click="Forward_Click"
                    ToolTip="Forward — restore the next workstation context (Ctrl+Right)" AutomationProperties.Name="Forward">
              <TextBlock Style="{StaticResource WorkstationChromeGlyph}" Text="&#xE72A;"/>
            </Button>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource WorkstationChromeSeparator}"/>

        <Border Background="{DynamicResource WorkstationChromeRaisedBrush}"
                BorderBrush="{DynamicResource WorkstationChromeQuietBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="3">
          <Button Style="{StaticResource WorkstationChromeButton}" IsEnabled="{Binding CanReforge}" Click="Reforge_Click"
                  ToolTip="{Binding ReforgeToolTip}" AutomationProperties.Name="Reforge">
            <StackPanel Orientation="Horizontal">
              <TextBlock Style="{StaticResource WorkstationChromeGlyph}" Text="&#xE72C;"/>
              <TextBlock Style="{StaticResource WorkstationChromeActionLabel}" Text="Reforge"/>
            </StackPanel>
          </Button>
        </Border>

        <Border Style="{StaticResource WorkstationChromeSeparator}"/>

        <Border Background="{DynamicResource WorkstationChromeRaisedBrush}"
                BorderBrush="{DynamicResource WorkstationChromeQuietBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="3">
          <Button Style="{StaticResource WorkstationChromeButton}" IsEnabled="{Binding CanUndo}" Click="Undo_Click"
                  ToolTip="{Binding UndoPreviewText}" AutomationProperties.Name="Undo">
            <StackPanel Orientation="Horizontal">
              <TextBlock Style="{StaticResource WorkstationChromeGlyph}" Text="&#xE7A7;"/>
              <TextBlock Style="{StaticResource WorkstationChromeActionLabel}" Text="Undo"/>
            </StackPanel>
          </Button>
        </Border>
      </StackPanel>

      <!-- This overlay spans the full command bar, so unequal side content can never move it. -->
      <Grid x:Name="SearchHost" Grid.ColumnSpan="3" Width="440" HorizontalAlignment="Center"
            VerticalAlignment="Center" Panel.ZIndex="120">
        <Border x:Name="SearchInputChrome">
          <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource WorkstationChromeSearchSurface}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsOpen, ElementName=SearchResultsPopup}" Value="True">
                  <Setter Property="CornerRadius" Value="8,8,0,0"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <Grid Height="40">
            <TextBox x:Name="GlobalSearchBox" Style="{StaticResource SearchBox}"
                     Background="Transparent" BorderThickness="0" Padding="40,0,74,0"
                     VerticalContentAlignment="Center" IsInactiveSelectionHighlightEnabled="False"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="Search RimForge"
                     ToolTip="Search visible mods, issues, graph nodes, or RimForge features."
                     GotKeyboardFocus="GlobalSearchBox_GotKeyboardFocus"
                     LostKeyboardFocus="GlobalSearchBox_LostKeyboardFocus"
                     PreviewMouseLeftButtonDown="GlobalSearchBox_PreviewMouseLeftButtonDown"
                     KeyDown="GlobalSearchBox_KeyDown"/>
            <TextBlock Style="{StaticResource WorkstationChromeGlyph}" Foreground="{DynamicResource TextMutedBrush}"
                       Text="&#xE721;" Margin="13,0,0,0" HorizontalAlignment="Left"
                       VerticalAlignment="Center" IsHitTestVisible="False"/>
            <TextBlock Text="{Binding SearchPromptText}" Margin="40,0,74,0"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" IsHitTestVisible="False">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Text, ElementName=GlobalSearchBox}" Value=""/>
                        <Condition Binding="{Binding IsKeyboardFocused, ElementName=GlobalSearchBox}" Value="False"/>
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Visibility" Value="Visible"/>
                    </MultiDataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,9,0"
                    BorderBrush="{DynamicResource WorkstationChromeQuietBorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="6,2" IsHitTestVisible="False">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Text, ElementName=GlobalSearchBox}" Value="">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <TextBlock Text="Ctrl+F" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
            </Border>
            <Button x:Name="SearchClearButton" Click="SearchClearButton_Click"
                    Width="28" MinWidth="28" Height="24" Padding="0" Margin="0,0,9,0"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    ToolTip="Clear the active search filter" AutomationProperties.Name="Clear search filter">
              <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource WorkstationChromeButton}">
                  <Setter Property="Visibility" Value="Visible"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Text, ElementName=GlobalSearchBox}" Value="">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock Style="{StaticResource WorkstationChromeGlyph}" FontSize="11" Text="&#xE711;"/>
            </Button>
          </Grid>
        </Border>

        <Popup x:Name="SearchResultsPopup" PlacementTarget="{Binding ElementName=SearchInputChrome}"
               Placement="Bottom" AllowsTransparency="True" StaysOpen="False" PopupAnimation="Fade"
               IsOpen="{Binding IsSearchFlyoutOpen, Mode=OneWay}">
          <Border Width="{Binding ActualWidth, ElementName=SearchInputChrome}" MaxHeight="440" Padding="6"
                  Background="{DynamicResource WorkstationChromeRaisedBrush}"
                  BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1,0,1,1"
                  CornerRadius="0,0,8,8">
            <Grid>
              <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
              <ListBox x:Name="SearchResultsList" ItemsSource="{Binding SearchDiscoveryResults}"
                       SelectedItem="{Binding SelectedSearchDiscoveryResult, Mode=TwoWay}"
                       BorderThickness="0" Background="Transparent"
                       Visibility="{Binding HasSearchDiscoveryResults, Converter={StaticResource BooleanToVisibilityConverter}}"
                       PreviewMouseLeftButtonUp="SearchResultsList_PreviewMouseLeftButtonUp"
                       MouseDoubleClick="SearchResultsList_MouseDoubleClick"
                       KeyDown="SearchResultsList_KeyDown"
                       AutomationProperties.Name="Unified search results">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="{x:Type search:SearchDiscoveryResult}">
                    <Grid Margin="7,6">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                  Visibility="{Binding ShowModIdentity, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Path Data="{Binding SourceIconGeometry}" Fill="White" Stretch="Uniform" Width="17" Height="17"
                              Margin="0,0,8,0" ToolTip="{Binding SourceToolTip}"/>
                        <ContentControl Style="{StaticResource ForgeDiagnosticAnvil}" Tag="{Binding HealthState}"
                                        Width="20" Height="20" ToolTip="{Binding HealthToolTip}" IsHitTestVisible="False"/>
                      </StackPanel>
                      <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="15"
                                 Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                                 Visibility="{Binding ShowKindGlyph, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="10" TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <StackPanel VerticalAlignment="Center" Margin="18,20"
                          Visibility="{Binding HasNoSearchDiscoveryResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="No matching results" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding SearchFlyoutMessage}" Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="10" Margin="0,4,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
              </StackPanel>

              <Border Grid.Row="1" BorderBrush="{DynamicResource WorkstationChromeQuietBorderBrush}"
                      BorderThickness="0,1,0,0" Margin="4,4,4,0" Padding="8,7,8,2">
                <TextBlock Text="{Binding CommandBarSearchSummaryText}" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           TextTrimming="CharacterEllipsis"/>
              </Border>
            </Grid>
          </Border>
        </Popup>
      </Grid>

      <Border Grid.Column="2" Style="{StaticResource WorkstationChromeStatusSurface}"
              ToolTip="{Binding CommandBarStatusDetail}" Panel.ZIndex="110">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <Grid Width="16" Height="16" Margin="0,0,9,0" VerticalAlignment="Center">
            <Ellipse Width="10" Height="10" Fill="{Binding CommandBarStatusBrush}"/>
            <Ellipse Width="16" Height="16" Stroke="{Binding CommandBarStatusBrush}" StrokeThickness="1" Opacity="0.28"/>
          </Grid>
          <StackPanel Grid.Column="1">
            <TextBlock Text="{Binding CommandBarStatusText}" FontWeight="SemiBold" FontSize="11"/>
            <TextBlock Text="{Binding CommandBarStatusDetail}" Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="9.5" MaxWidth="220" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </Grid>
      </Border>

      <Popup x:Name="NavigationMenuPopup" PlacementTarget="{Binding ElementName=NavigationMenuButton}"
             Placement="Bottom" AllowsTransparency="True" StaysOpen="False" PopupAnimation="Fade">
        <Border Width="286" Margin="0,8,0,0" Padding="10"
                Background="{DynamicResource WorkstationChromeRaisedBrush}"
                BorderBrush="{DynamicResource WorkstationChromeBorderBrush}" BorderThickness="1" CornerRadius="8">
          <StackPanel>
            <Grid Margin="8,5,8,10">
              <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
              <Image Source="/RimForge.UI;component/Assets/Branding/Badge/RimForge.Badge.png" Width="34" Height="34"/>
              <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="RimForge" FontWeight="Bold" FontSize="16"/>
                <TextBlock Text="We're not just managing your mods—we're forging stable, optimized modpack ecosystems."
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="9" LineHeight="11"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Grid>
            <TextBlock Text="WORKSPACE" Style="{StaticResource NavSectionHeading}" Margin="8,2,8,4"/>
            <Button x:Name="ModSorterNavigationButton" Style="{StaticResource WorkstationChromeButton}" Tag="Mod Sorter"
                    HorizontalContentAlignment="Stretch" Click="NavigationDestination_Click">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Image Source="/RimForge.UI;component/Assets/Branding/Badge/RimForge.Badge.png" Width="22" Height="22" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="1" Text="Mod Sorter" HorizontalAlignment="Left" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <Button x:Name="IssueViewerNavigationButton" Style="{StaticResource WorkstationChromeButton}" Tag="Issue Viewer"
                    HorizontalContentAlignment="Stretch" Click="NavigationDestination_Click">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Image Source="/RimForge.UI;component/Assets/Branding/Badge/RimForge.Badge.png" Width="22" Height="22" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="1" Text="Issue Viewer" HorizontalAlignment="Left" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <Button x:Name="ForgeViewNavigationButton" Style="{StaticResource WorkstationChromeButton}" Tag="ForgeView"
                    HorizontalContentAlignment="Stretch" Click="NavigationDestination_Click">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Image Source="/RimForge.UI;component/Assets/Branding/Badge/RimForge.Badge.png" Width="22" Height="22" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="1" Text="ForgeView" HorizontalAlignment="Left" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <TextBlock Text="TOOLS" Style="{StaticResource NavSectionHeading}" Margin="8,10,8,4"/>
            <Button x:Name="TextureToolsNavigationButton" Style="{StaticResource WorkstationChromeButton}" Tag="Texture Tools"
                    HorizontalContentAlignment="Stretch" Click="NavigationDestination_Click">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Image Source="/RimForge.UI;component/Assets/Branding/Badge/RimForge.Badge.png" Width="22" Height="22" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="1" Text="Texture Conversion Tools" HorizontalAlignment="Left" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <Button x:Name="ConsoleNavigationButton" Style="{StaticResource WorkstationChromeButton}" Tag="Console"
                    HorizontalContentAlignment="Stretch" Click="NavigationDestination_Click">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Image Source="/RimForge.UI;component/Assets/Branding/Badge/RimForge.Badge.png" Width="22" Height="22" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="1" Text="Console" HorizontalAlignment="Left" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <Button x:Name="SettingsNavigationButton" Style="{StaticResource WorkstationChromeButton}" Tag="Settings"
                    HorizontalContentAlignment="Stretch" Click="NavigationDestination_Click">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Image Source="/RimForge.UI;component/Assets/Branding/Badge/RimForge.Badge.png" Width="22" Height="22" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="1" Text="Settings" HorizontalAlignment="Left" VerticalAlignment="Center"/>
              </Grid>
            </Button>
          </StackPanel>
        </Border>
      </Popup>
    </Grid>
  </Border>
</UserControl>
