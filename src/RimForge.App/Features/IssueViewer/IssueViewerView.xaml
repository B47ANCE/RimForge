<UserControl x:Class="RimForge.App.Features.IssueViewer.IssueViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:forge="clr-namespace:RimForge.UI.Controls;assembly=RimForge.UI">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="14,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="ISSUE VIEWER" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
          <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
            <TextBlock Text="{Binding IssueViewerScopeText}" FontSize="17" FontWeight="SemiBold"/>
            <TextBlock Text="  —  " FontSize="17" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock Text="{Binding IssueViewerStatusText}" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}"/>
          </StackPanel>
          <TextBlock Text="Review what is wrong, why it matters, and what RimForge recommends next." Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
          <TextBlock Text="{Binding IssueSearchSummaryText}" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
          <forge:ForgeCheckBox Content="Full Library" IsChecked="{Binding ShowFullLibrary}" VerticalAlignment="Center" ToolTip="Show issues across every installed mod instead of only the active profile" Margin="0,0,12,0"/>
          <Button Style="{StaticResource SecondaryButton}" Content="Fix All Issues" Click="FixAllIssues_Click" IsEnabled="{Binding HasAutoFixableIssues}"/>
        </StackPanel>
      </Grid>
    </Border>
    <Border Grid.Row="1" Padding="0" ClipToBounds="True" MaxHeight="560">
      <Border.Style>
        <Style TargetType="Border" BasedOn="{StaticResource Card}">
          <Setter Property="Visibility" Value="Visible"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding HasIssueViewerItems}" Value="False">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <ListBox x:Name="IssueList"
               ItemsSource="{Binding IssueItemsView}"
               SelectedItem="{Binding SelectedIssueItem}"
               Background="Transparent"
               BorderThickness="0"
               Padding="10"
               ScrollViewer.VerticalScrollBarVisibility="Visible"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               ScrollViewer.CanContentScroll="True"
               VirtualizingPanel.IsVirtualizing="True"
               VirtualizingPanel.VirtualizationMode="Recycling">
        <ListBox.GroupStyle>
          <GroupStyle>
            <GroupStyle.HeaderTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource Bg3Brush}" CornerRadius="8" Padding="12,8" Margin="0,8,0,6">
                  <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                </Border>
              </DataTemplate>
            </GroupStyle.HeaderTemplate>
          </GroupStyle>
          <GroupStyle>
            <GroupStyle.HeaderTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" Margin="8,8,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
              </DataTemplate>
            </GroupStyle.HeaderTemplate>
          </GroupStyle>
        </ListBox.GroupStyle>
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
          </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border CornerRadius="10" Padding="14" Opacity="{Binding DisplayOpacity}"><Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource Bg3Brush}"/><Setter Property="BorderBrush" Value="{DynamicResource Bg4Brush}"/><Setter Property="BorderThickness" Value="1"/><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsSearchActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/><Setter Property="BorderThickness" Value="2"/></DataTrigger></Style.Triggers></Style></Border.Style>
              <Expander IsExpanded="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Mode=OneWay}">
                <Expander.Header>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Padding="8,4" CornerRadius="10" Margin="0,0,12,0">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="{DynamicResource Bg4Brush}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Severity}" Value="Error"><Setter Property="Background" Value="#33EF5350"/></DataTrigger>
                            <DataTrigger Binding="{Binding Severity}" Value="Warning"><Setter Property="Background" Value="#33F2B84B"/></DataTrigger>
                            <DataTrigger Binding="{Binding Severity}" Value="Information"><Setter Property="Background" Value="#334DA3FF"/></DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <TextBlock Text="{Binding SeverityLabel}" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"/>
                      <Button Content="{Binding ModName}"
                              Tag="{Binding PackageId}"
                              Click="InspectMod_Click"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0"
                              HorizontalAlignment="Left"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              Cursor="Hand"
                              ToolTip="Inspect this mod"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding ResolutionLabel}" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                  </Grid>
                </Expander.Header>
                <StackPanel Margin="34,14,0,0">
                  <TextBlock Text="WHAT RIMFORGE FOUND" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                  <TextBlock Text="{Binding Explanation}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                  <TextBlock Text="WHY IT MATTERS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                  <TextBlock Text="{Binding WhyItMatters}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                  <TextBlock Text="RECOMMENDED NEXT STEP" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                  <TextBlock Text="{Binding RecommendedAction}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                  <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="RELATED MODS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                    <ItemsControl ItemsSource="{Binding RelatedMods}" Margin="0,5,0,0">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Content="{Binding DisplayName}"
                                  Tag="{Binding PackageId}"
                                  Click="RelatedMod_Click"
                                  Style="{StaticResource SecondaryButton}"
                                  Padding="9,4"
                                  Margin="0,0,6,6"
                                  ToolTip="Inspect this related mod"/>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="None" Foreground="{DynamicResource TextMutedBrush}" Margin="0,5,0,0">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding RelatedMods.Count}" Value="0">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </StackPanel>
                  <Expander Header="Technical details" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12">
                    <StackPanel Margin="12,8,0,0">
                      <TextBlock Text="{Binding PackageId, StringFormat='Package ID: {0}'}" FontFamily="Cascadia Mono,Consolas" TextWrapping="Wrap"/>
                      <TextBlock Text="{Binding Code, StringFormat='Issue code: {0}'}" FontFamily="Cascadia Mono,Consolas" Margin="0,4,0,0"/>
                      <TextBlock Text="{Binding RepairAction, StringFormat='Repair provider: {0}'}" FontFamily="Cascadia Mono,Consolas" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Expander>
                  <WrapPanel>
                    <Button Style="{StaticResource SecondaryButton}" Content="Inspect Mod" Tag="{Binding PackageId}" Click="InspectMod_Click" Padding="12,6" Margin="0,0,8,8"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Open in ForgeView" Tag="{Binding PackageId}" Click="OpenInForgeView_Click" Padding="12,6" Margin="0,0,8,8"/>
                    <Button Content="Preview Repair" Click="FixSelectedIssue_Click" Padding="12,6" Margin="0,0,8,8">
                      <Button.Style><Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding CanAutoFix}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Button.Style>
                    </Button>
                    <Button Content="Fix Issue" Click="FixSelectedIssue_Click" Padding="12,6" Margin="0,0,8,8" IsEnabled="{Binding CanAutoFix}">
                      <Button.Style><Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CanAutoFix}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger><DataTrigger Binding="{Binding IsIgnored}" Value="True"><Setter Property="IsEnabled" Value="False"/></DataTrigger></Style.Triggers></Style></Button.Style>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Content="{Binding IgnoreActionLabel}" Click="ToggleIgnore_Click" Padding="12,6" Margin="0,0,0,8"/>
                  </WrapPanel>
                </StackPanel>
              </Expander>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
    <Border Grid.Row="1" Padding="18,14">
      <Border.Style>
        <Style TargetType="Border" BasedOn="{StaticResource Card}">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding HasIssueViewerItems}" Value="False">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel Orientation="Horizontal">
        <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
        <TextBlock Text="No issues detected in the current scope." FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
