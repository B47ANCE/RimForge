<UserControl x:Class="RimForge.App.Features.Settings.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:forge="clr-namespace:RimForge.UI.Controls;assembly=RimForge.UI">
  <Border Style="{StaticResource Card}" Padding="18" ClipToBounds="True">
  <Grid MinHeight="480">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Margin="0,0,0,16">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="Settings" FontSize="30" FontWeight="Bold"/>
        <TextBlock Text="Configure the RimForge workstation through independently scrolling workspaces."
                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,5,0,0"/>
      </StackPanel>
      <Border Grid.Column="1" Background="{DynamicResource WorkstationChromeRaisedBrush}"
              BorderBrush="{DynamicResource WorkstationChromeQuietBorderBrush}" BorderThickness="1"
              CornerRadius="7" Padding="10,6" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,7,0"/>
          <TextBlock Text="Workstation configuration" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </Border>
    </Grid>

    <TabControl Grid.Row="1" x:Name="SettingsTabs" Background="Transparent" BorderThickness="0">
      <TabItem Header="General">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,16,16,0">
          <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="PATHS" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="Steam Workshop Folder" Style="{StaticResource InspectorLabel}"/>
                <TextBox Text="{Binding WorkshopFolder, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBox}" Margin="0,4,0,14"/>
                <TextBlock Text="Local RimWorld Mods Folder" Style="{StaticResource InspectorLabel}"/>
                <TextBox Text="{Binding LocalModsFolder, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBox}" Margin="0,4,0,14"/>
                <Button Style="{StaticResource SecondaryButton}" Content="Search Steam Libraries" HorizontalAlignment="Left" Margin="0,0,0,14" Click="SearchSteamLibraries_Click"/>
                <TextBlock Text="Output Folder" Style="{StaticResource InspectorLabel}"/>
                <TextBox Text="{Binding OutputFolderSetting, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBox}" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="RIMWORLD VERSION" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="Analysis Target" Style="{StaticResource InspectorLabel}"/>
                <ComboBox ItemsSource="{Binding RimWorldVersions}" SelectedItem="{Binding TargetRimWorldVersion}" Width="180" HorizontalAlignment="Left" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Appearance">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,16,16,0">
          <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="INTERFACE" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="Navigation is available from the compact menu in the command bar."
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                <forge:ForgeCheckBox Content="Show forge narrative messages" IsChecked="{Binding ShowForgeNarrative}" Margin="0,0,0,10"/>
                <forge:ForgeCheckBox Content="Open console on game launch" IsChecked="{Binding OpenConsoleOnGameLaunch}"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="SKIN MANAGER" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="RimForge Industrial" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="The default skin is active. Community skin loading will use the semantic resource framework established before 1.0."
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem x:Name="ProfilesTab" Header="Profiles">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,16,16,0">
          <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="PROFILE MANAGEMENT" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="Create, rename, favorite, import, export, compare, lock, and delete profile workspaces from one administration surface."
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                <forge:ForgeProfileToolbar HorizontalAlignment="Left"
                                           CanRename="{Binding CanRenameSelectedProfile}"
                                           CanLock="{Binding CanLockSelectedProfile}"
                                           CanDelete="{Binding CanDeleteSelectedProfile}"
                                           IsLocked="{Binding IsSelectedProfileLocked}"
                                           IsFavorite="{Binding IsSelectedProfileFavorite}"
                                           CreateRequested="ProfileCreate_Click"
                                           RenameRequested="ProfileRename_Click"
                                           OpenRequested="ProfileOpen_Click"
                                           DuplicateRequested="ProfileDuplicate_Click"
                                           FavoriteRequested="ProfileFavorite_Click"
                                           ImportRequested="ProfileImport_Click"
                                           ExportRequested="ProfileExport_Click"
                                           CompareRequested="ProfileCompare_Click"
                                           LockRequested="ProfileLock_Click"
                                           DeleteRequested="ProfileDelete_Click"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="ACTIVE WORKSPACE" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="{Binding SelectedProfile.Name}" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SelectedProfileModCountText}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding SelectedProfileStateText}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Automation">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,16,16,0">
          <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="LOAD-ORDER POLICY" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="Sorting mode" Style="{StaticResource InspectorLabel}"/>
                <ComboBox ItemsSource="{Binding LoadOrderSortingModes}" SelectedItem="{Binding LoadOrderSortingPreference}" Width="240" HorizontalAlignment="Left" Margin="0,4,0,12"/>
                <forge:ForgeCheckBox Content="Later category bands override earlier matches" IsChecked="{Binding LaterBandsOverrideEarlier}" Margin="0,0,0,8"/>
                <forge:ForgeCheckBox Content="Non-anchor dependency reconciliation moves downward only" IsChecked="{Binding ReconcileDependenciesDownwardOnly}" Margin="0,0,0,8"/>
                <forge:ForgeCheckBox Content="Curated anchors may move in either direction" IsChecked="{Binding CuratedAnchorsBidirectional}"/>
                <TextBlock Text="Rule-pack foundation: rimforge.category-first.v1" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="DEPENDENCY ASSISTANCE" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="Activation behavior" Style="{StaticResource InspectorLabel}"/>
                <ComboBox ItemsSource="{Binding DependencyAssistanceModes}" SelectedItem="{Binding DependencyAssistancePreference}" Width="220" HorizontalAlignment="Left" Margin="0,4,0,14"/>
                <TextBlock Text="Orphan cleanup behavior" Style="{StaticResource InspectorLabel}"/>
                <ComboBox ItemsSource="{Binding OrphanCleanupModes}" SelectedItem="{Binding OrphanCleanupPreference}" Width="220" HorizontalAlignment="Left" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Advanced">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,16,16,0">
          <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="NETWORK" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="External Check Timeout (seconds)" Style="{StaticResource InspectorLabel}"/>
                <TextBox Text="{Binding ExternalTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchBox}" Width="180" HorizontalAlignment="Left" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="WORKSTATION OPERATIONS" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="Reforge performs an in-process workstation refresh while preserving the current page, profile, search query, and selected mod whenever those entities remain available."
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                <TextBlock Text="Use the permanent Reforge command in the Engineering Command Bar."
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0">
      <Button Style="{StaticResource PrimaryButton}" Content="Save Settings" Click="SaveSettings_Click"/>
      <TextBlock Text="{Binding SettingsStatus}" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
    </StackPanel>
  </Grid>
  </Border>
</UserControl>
