<UserControl x:Class="RimForge.App.Features.ModInspector.ModInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
  </UserControl.Resources>
  <Border Background="{StaticResource Bg1Brush}"
          CornerRadius="10,0,0,10"
          ClipToBounds="True"
          BorderBrush="{DynamicResource Bg4Brush}"
          BorderThickness="1,1,0,1">
    <Grid>
          <Grid x:Name="InspectorCollapsedRail" Visibility="Collapsed">
            <Button Style="{StaticResource SecondaryButton}" Width="32" Height="44" Padding="0"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"
                    ToolTip="Open Mod Inspector" Click="ToggleButton_Click">
              <TextBlock Text="◀" FontSize="14"/>
            </Button>
            <TextBlock Text="INSPECTOR" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                       FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock.LayoutTransform>
                <RotateTransform Angle="-90"/>
              </TextBlock.LayoutTransform>
            </TextBlock>
          </Grid>
          <Grid x:Name="InspectorExpandedContent">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
          <Grid Margin="14,10,10,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="MOD INSPECTOR" Style="{StaticResource InspectorSectionHeader}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="▶" Width="32" Height="28" Padding="0" ToolTip="Collapse Mod Inspector" Click="ToggleButton_Click"/>
          </Grid>
          <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
            <StackPanel>
              <Grid Height="188" Background="{StaticResource Bg0Brush}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Text="⚒" FontSize="34" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                  <TextBlock Text="Mod Inspector" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
                <Image Source="{Binding SelectedInspectorPreviewImagePath}" Stretch="UniformToFill"/>
                <Border VerticalAlignment="Bottom" Height="74">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#001E1F22" Offset="0"/>
                      <GradientStop Color="#E61E1F22" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                  <TextBlock Text="{Binding SelectedInspectorDisplayName}" FontSize="20" FontWeight="Bold" Margin="18,0,18,14" VerticalAlignment="Bottom" TextWrapping="Wrap"/>
                </Border>
              </Grid>
              <StackPanel Margin="18">
                <TextBlock Text="NAVIGATION" Style="{StaticResource InspectorSectionHeader}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <Button Content="↑ Previous" Style="{StaticResource SecondaryButton}" IsEnabled="{Binding CanNavigateSelectionBack}" Click="SelectionBackButton_Click" Margin="0,0,6,0"/>
                  <Button Grid.Column="1" Content="Next ↓" Style="{StaticResource SecondaryButton}" IsEnabled="{Binding CanNavigateSelectionForward}" Click="SelectionForwardButton_Click"/>
                </Grid>
                <TextBlock Text="{Binding SelectionBreadcrumb}" Foreground="{DynamicResource AccentBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <Button Style="{StaticResource SecondaryButton}" Content="Open Installation Folder" Margin="0,0,0,16" Click="OpenFolderButton_Click"/>

                <StackPanel Margin="0,0,0,16" Visibility="{Binding IsSelectedSteamContent, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <TextBlock Text="{Binding SelectedSteamContentMetadata.SectionTitle, TargetNullValue=STEAM}" Style="{StaticResource InspectorSectionHeader}" Margin="0,0,0,8"/>
                  <TextBlock Text="{Binding SelectedSteamContentStatusText}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="11"
                             TextWrapping="Wrap"
                             Margin="0,0,0,8">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding SelectedSteamContentStatusText}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <StackPanel Visibility="{Binding HasSelectedSteamContentMetadata, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding SelectedSteamContentMetadata.Name}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SelectedSteamContentMetadata.Description}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="{Binding SelectedSteamContentMetadata.CreatorLabel, TargetNullValue=Creator}" Style="{StaticResource InspectorLabel}"/>
                        <TextBlock Text="{Binding SelectedSteamContentMetadata.CreatorDisplay, TargetNullValue=Unknown}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="{Binding SelectedSteamContentMetadata.DateLabel, TargetNullValue=Updated}" Style="{StaticResource InspectorLabel}"/>
                        <TextBlock Text="{Binding SelectedSteamContentMetadata.DateDisplay, TargetNullValue=Unknown}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                      </StackPanel>
                    </Grid>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Content="Browser" Margin="0,0,5,0" Click="OpenBrowserButton_Click"/>
                      <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Steam" Margin="5,0,0,0" Click="OpenSteamButton_Click"/>
                    </Grid>
                  </StackPanel>
                </StackPanel>

                <TextBlock Text="WORKSPACE" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="Profile State" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedInspectorProfileState}" Margin="0,2,0,12"/>
                <TextBlock Text="Load Order" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedInspectorLoadOrderText}" Margin="0,2,0,12"/>
                <TextBlock Text="Source" Style="{StaticResource InspectorLabel}"/>
                <Grid Margin="0,4,0,16">
                  <Path Data="{Binding SelectedInspectorSourceIconGeometry}" Fill="White" Stretch="Uniform" Width="18" Height="18" HorizontalAlignment="Left" ToolTip="{Binding SelectedInspectorSourceToolTip}" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0" ToolTipService.ShowDuration="60000">
                    <Path.Style>
                      <Style TargetType="Path">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding SelectedMod}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Path.Style>
                  </Path>
                  <TextBlock Text="Select a mod to view its source." Foreground="{DynamicResource TextMutedBrush}" FontSize="10">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding SelectedMod}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Grid>
                <TextBlock Text="INFORMATION" Style="{StaticResource InspectorSectionHeader}"/>
                <TextBlock Text="Health" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedMod.HealthText, TargetNullValue=Unknown}" Margin="0,2,0,12"/>
                <TextBlock Text="Author" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedMod.Author, TargetNullValue=Unknown}" Margin="0,2,0,12"/>
                <TextBlock Text="Package ID" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedMod.DisplayPackageId, TargetNullValue=—}" Margin="0,2,0,12" TextWrapping="Wrap"/>
                <TextBlock Text="Supported Versions" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedMod.SupportedVersionsText, TargetNullValue=Unknown}" Margin="0,2,0,12"/>
                <TextBlock Text="Dependencies" Style="{StaticResource InspectorLabel}"/>
                <ItemsControl ItemsSource="{Binding SelectedDependencyMods}" Margin="0,4,0,12">
                  <ItemsControl.ItemTemplate><DataTemplate><Button Tag="{Binding PackageId}" Content="{Binding DisplayName}" Style="{StaticResource SecondaryButton}" HorizontalContentAlignment="Left" Padding="7,3" Margin="0,0,0,4" Click="RelatedModButton_Click"/></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="FORGE DNA" Style="{StaticResource InspectorSectionHeader}" Margin="0,4,0,8"/>
                <TextBlock Text="{Binding SelectedMod.Evidence.InventorySummary, TargetNullValue='No evidence scanned'}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,0,0,7"/>
                <ItemsControl ItemsSource="{Binding SelectedMod.Evidence.Badges}" ItemTemplate="{DynamicResource ForgeEvidenceBadgeTemplate}" Margin="-3,0,0,8" Visibility="{Binding SelectedInspectorShowEvidenceBadges, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
                <TextBlock Text="Capabilities" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedMod.Evidence.CapabilityText, TargetNullValue='No capabilities inferred.'}" TextWrapping="Wrap" FontSize="10" Margin="0,2,0,12"/>
                <TextBlock Text="RUNTIME EVIDENCE" Style="{StaticResource InspectorSectionHeader}" Margin="0,4,0,8"/>
                <TextBlock Text="{Binding SelectedRuntimeEvidenceSummary}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding SelectedRuntimeEvidence}" Margin="0,0,0,12">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="7" Margin="0,0,0,5">
                        <StackPanel>
                          <DockPanel LastChildFill="True">
                            <TextBlock Text="{Binding Severity}" FontSize="9" FontWeight="SemiBold" Margin="0,0,7,0"/>
                            <TextBlock Text="{Binding Title}" FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap"/>
                          </DockPanel>
                          <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" TextWrapping="Wrap" Margin="0,3,0,0"/>
                          <TextBlock Text="{Binding OccurrenceCount, StringFormat='Observed {0} time(s)'}" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" Margin="0,3,0,0"/>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="ANALYSIS" Style="{StaticResource InspectorSectionHeader}" Margin="0,4,0,8"/>
                <TextBlock Text="Dependents" Style="{StaticResource InspectorLabel}"/>
                <ItemsControl ItemsSource="{Binding SelectedDependentMods}" Margin="0,4,0,12">
                  <ItemsControl.ItemTemplate><DataTemplate><Button Tag="{Binding PackageId}" Content="{Binding DisplayName}" Style="{StaticResource SecondaryButton}" HorizontalContentAlignment="Left" Padding="7,3" Margin="0,0,0,4" Click="RelatedModButton_Click"/></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="DEPENDENCY MANAGEMENT" Style="{StaticResource InspectorSectionHeader}" Margin="0,4,0,8"/>
                <TextBlock Text="{Binding DependencyManagementHealthText}" Margin="0,2,0,5" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding DependencyManagementCountsText}" Margin="0,0,0,12" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                <TextBlock Text="DEPENDENCY INTELLIGENCE" Style="{StaticResource InspectorSectionHeader}" Margin="0,4,0,8"/>
                <TextBlock Text="Summary" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedDependencySummary}" Margin="0,2,0,8" TextWrapping="Wrap"/>
                <TextBlock Text="Why is this enabled?" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedWhyEnabledText}" Margin="0,2,0,8" TextWrapping="Wrap" FontSize="11"/>
                <TextBlock Text="What happens if it is removed?" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedRemovalImpactText}" Margin="0,2,0,8" TextWrapping="Wrap" FontSize="11"/>
                <TextBlock Text="{Binding SelectedDependencyConfidenceText}" Margin="0,0,0,8" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                <ItemsControl ItemsSource="{Binding SelectedRemovalImpactMods}" Margin="0,0,0,12">
                  <ItemsControl.ItemTemplate><DataTemplate><Button Tag="{Binding PackageId}" Content="{Binding DisplayName}" Style="{StaticResource SecondaryButton}" HorizontalContentAlignment="Left" Padding="7,3" Margin="0,0,0,4" Click="RelatedModButton_Click" ToolTip="{Binding Explanation}"/></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="Impact" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedSorterItem.ImpactLabel, TargetNullValue='No dependents'}" Margin="0,2,0,12" TextWrapping="Wrap"/>
                <TextBlock Text="LOAD-ORDER DECISION" Style="{StaticResource InspectorSectionHeader}" Margin="0,4,0,8"/>
                <TextBlock Text="{Binding SelectedSorterItem.SortDecisionLabel, TargetNullValue='Not analyzed'}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding SelectedSorterItem.SortMovementText, TargetNullValue='No proposed position'}" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding SelectedSorterItem.SortReason, TargetNullValue='Run Forge to calculate an explainable load-order recommendation.'}" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding SelectedSorterItem.SortRuleSource, StringFormat='Source: {0}', TargetNullValue='Source: Not analyzed'}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,0,0,12" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SelectedAnalysisSectionTitle}" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedAnalysisStatusText}" Margin="0,2,0,6" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedAnalysisIsHealthy}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <StackPanel>
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Collapsed"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedSorterItem.IsInCycle}" Value="True">
                          <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <TextBlock Text="Cycle State" Style="{StaticResource InspectorLabel}"/>
                  <TextBlock Text="{Binding SelectedSorterItem.CycleLabel}" Margin="0,2,0,12" Foreground="{DynamicResource DangerBrush}" FontWeight="SemiBold"/>
                </StackPanel>
                <TextBlock Text="{Binding SelectedAnalysisSummaryTitle}" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedAnalysisExplanation}" Margin="0,2,0,8" TextWrapping="Wrap" FontSize="11"/>
                <TextBlock Text="{Binding SelectedAnalysisVerifiedText}" Margin="0,0,0,12" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource TextMutedBrush}">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Visibility" Value="Visible"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedAnalysisIsHealthy}" Value="False">
                          <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="Affected Mods" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedDependentPreview}" Margin="0,2,0,12" TextWrapping="Wrap" FontSize="11"/>
                <TextBlock Text="Recommended Actions" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedRecommendationText}" Margin="0,2,0,12" TextWrapping="Wrap" FontSize="11"/>
                <TextBlock Text="Installation Path" Style="{StaticResource InspectorLabel}"/>
                <TextBlock Text="{Binding SelectedMod.RootPath, TargetNullValue='No installation path available.'}" Margin="0,2,0,18" TextWrapping="Wrap" FontSize="11"/>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
          </Grid>

    </Grid>
  </Border>
</UserControl>
