<UserControl x:Class="RimForge.App.Features.Console.ConsoleView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
    <Grid>
      <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
      <Grid Margin="18,16,18,10">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="Console" FontSize="30" FontWeight="Bold"/>
          <TextBlock Text="RimForge activity and live RimWorld Player.log output." Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
        </StackPanel>
        <Border Grid.Column="1" Background="{DynamicResource VisualSurfaceRaisedBrush}" BorderBrush="{DynamicResource VisualBorderBrush}" BorderThickness="1" CornerRadius="7" Padding="10,6" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,7,0"/><TextBlock Text="Console workspace" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/></StackPanel>
        </Border>
      </Grid>
      <TabControl Grid.Row="1" Grid.RowSpan="2" x:Name="ConsoleTabs" Style="{StaticResource ForgeTabControl}" Margin="18,0,18,16">
        <TabItem x:Name="ActivityTab" Header="Activity Feed">
          <Border Style="{StaticResource ConsoleSurface}" Margin="0,8,0,0">
            <Grid Margin="14"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
              <TextBlock Text="Native engine and Forge Session output" Margin="0,0,0,10" Foreground="{DynamicResource TextMutedBrush}"/>
              <ListBox Grid.Row="1" ItemsSource="{Binding ActivityEntries}" Style="{StaticResource ActivityFeedBox}" ItemContainerStyle="{StaticResource ActivityItemContainer}" ScrollViewer.VerticalScrollBarVisibility="Visible">
                <ListBox.ItemTemplate><DataTemplate><Grid Margin="6,4"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding TimeText}" FontFamily="Cascadia Mono,Consolas" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/><TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas"/></Grid></DataTemplate></ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>
        </TabItem>
        <TabItem x:Name="GameLogTab" Header="RimWorld Game Log">
          <Border Style="{StaticResource ConsoleSurface}" Margin="0,8,0,0">
            <Grid Margin="14"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10"><Button Style="{StaticResource PrimaryButton}" Content="Start Watching" Click="Start_Click" Margin="0,0,8,0"/><Button Style="{StaticResource SecondaryButton}" Content="Stop" Click="Stop_Click" Margin="0,0,8,0"/><Button Style="{StaticResource SecondaryButton}" Content="Clear View" Click="Clear_Click"/><TextBlock Text="Player.log streams automatically when RimWorld is launched through RimForge." Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/></StackPanel>
              <ListBox x:Name="GameLogList" Grid.Row="1" ItemsSource="{Binding GameLogEntries}" Style="{StaticResource ActivityFeedBox}" Padding="6" ScrollViewer.VerticalScrollBarVisibility="Visible" ScrollViewer.CanContentScroll="False" ScrollViewer.ScrollChanged="GameLogList_ScrollChanged">
                <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Focusable" Value="False"/></Style></ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate><DataTemplate><Grid Margin="3,1"><Grid.ColumnDefinitions><ColumnDefinition Width="62"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding TimeText}" FontFamily="Cascadia Mono,Consolas" FontSize="10" LineHeight="14" LineStackingStrategy="BlockLineHeight" Foreground="{DynamicResource TextMutedBrush}"/><TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas" FontSize="10.5" LineHeight="14" LineStackingStrategy="BlockLineHeight"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding Severity}" Value="Warning"><Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/></DataTrigger><DataTrigger Binding="{Binding Severity}" Value="Error"><Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></Grid></DataTemplate></ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>
        </TabItem>
      </TabControl>
    </Grid>
  </Border>
</UserControl>
