<Window x:Class="RimForge.UI.Dialogs.ForgeDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:RimForge.UI.Controls"
        Width="560"
        SizeToContent="Height"
        MinHeight="270"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        KeyDown="Window_KeyDown">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    <Style x:Key="DialogIconButton" TargetType="Button">
      <Setter Property="Width" Value="36"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Surface" Background="{TemplateBinding Background}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Surface" Property="Background" Value="{DynamicResource Bg3Brush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Surface" Property="Background" Value="{DynamicResource Bg4Brush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="DialogSecondaryButton" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource Bg3Brush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="#20FFFFFF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="18,11"/>
      <Setter Property="MinHeight" Value="42"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Bg4Brush}"/>
                <Setter TargetName="Root" Property="BorderBrush" Value="#38FFFFFF"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DialogPrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="18,11"/>
      <Setter Property="MinHeight" Value="42"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                <Setter TargetName="Root" Property="Effect">
                  <Setter.Value><DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.30" Color="#D97735"/></Setter.Value>
                </Setter>
              </Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter TargetName="Root" Property="Opacity" Value="0.86"/></Trigger>
              <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="DialogDangerButton" TargetType="Button">
      <Setter Property="Background" Value="#241F2023"/>
      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="18,11"/>
      <Setter Property="MinHeight" Value="42"/>
      <Setter Property="MinWidth" Value="108"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#3A3A171B"/>
                <Setter TargetName="Root" Property="Effect">
                  <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.22" Color="#E5484D"/>
                  </Setter.Value>
                </Setter>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#54241116"/>
                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border x:Name="RootChrome"
          Margin="18"
          Opacity="0"
          RenderTransformOrigin="0.5,0.5"
          Background="{DynamicResource Bg1Brush}"
          BorderBrush="#3A47525E"
          BorderThickness="1"
          CornerRadius="14">
    <Border.RenderTransform>
      <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
    </Border.RenderTransform>
    <Border.Triggers>
      <EventTrigger RoutedEvent="FrameworkElement.Loaded">
        <BeginStoryboard>
          <Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.16">
              <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
              </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18">
              <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
              </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18">
              <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
              </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>
    </Border.Triggers>
    <Border.Effect>
      <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.56" Color="#000000"/>
    </Border.Effect>
    <Grid>
      <Border Margin="1" BorderBrush="#24D97735" BorderThickness="0.5" CornerRadius="13" IsHitTestVisible="False"/>
      <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="50"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Background="{DynamicResource Bg2Brush}"
              BorderBrush="#24FFFFFF"
              BorderThickness="0,0,0,1"
              CornerRadius="14,14,0,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid Margin="15,0,12,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Border Width="24" Height="24" CornerRadius="5" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" Background="#1FD97735">
            <controls:ForgeIcon Kind="{Binding DialogIconKind, RelativeSource={RelativeSource AncestorType=Window}}" Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center" IconBrush="{DynamicResource AccentBrush}"/>
          </Border>
          <TextBlock Grid.Column="1"
                     Margin="10,0,0,0"
                     Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType=Window}}"
                     FontSize="15"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <Button Grid.Column="2" Margin="0,0,2,0" Style="{StaticResource DialogIconButton}" Click="Close_Click" ToolTip="Close">
            <Path Width="14" Height="14" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M1,1 L13,13 M13,1 L1,13"/>
          </Button>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="30,26,30,32">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Heading, RelativeSource={RelativeSource AncestorType=Window}}"
                   FontSize="25"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1"
                   Text="{Binding Message, RelativeSource={RelativeSource AncestorType=Window}}"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <ContentControl Grid.Row="2"
                        Content="{Binding DetailContent, RelativeSource={RelativeSource AncestorType=Window}}">
          <ContentControl.Style>
            <Style TargetType="ContentControl">
              <Setter Property="Margin" Value="0,0,0,18"/>
              <Style.Triggers>
                <Trigger Property="Content" Value="{x:Null}">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Setter Property="Margin" Value="0"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ContentControl.Style>
        </ContentControl>

        <TextBox x:Name="InputBox"
                 Grid.Row="3"
                 Text="{Binding InputText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="15"
                 MinHeight="56"
                 Padding="14,13"
                 Margin="0,0,0,26"
                 Visibility="{Binding IsInputVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="CancelButton"
                  Content="Cancel"
                  MinWidth="108"
                  Visibility="{Binding IsCancelVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"
                  IsCancel="True"
                  Style="{StaticResource DialogSecondaryButton}"
                  Click="Cancel_Click">
            <Button.ContentTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal">
                  <Path Width="14" Height="14" Margin="0,0,9,0" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6" Data="M1,1 L13,13 M13,1 L1,13"/>
                  <TextBlock Text="Cancel"/>
                </StackPanel>
              </DataTemplate>
            </Button.ContentTemplate>
          </Button>
          <Button x:Name="PrimaryButton"
                  MinWidth="108"
                  Margin="12,0,0,0"
                  IsDefault="True"
                  Style="{StaticResource DialogPrimaryButton}"
                  Click="Primary_Click">
            <StackPanel Orientation="Horizontal">
              <controls:ForgeIcon x:Name="PrimaryIcon" Kind="{Binding PrimaryIconKind, RelativeSource={RelativeSource AncestorType=Window}}" Width="15" Height="15" Margin="0,0,9,0" IconBrush="White"/>
              <TextBlock x:Name="PrimaryButtonLabel" Text="Save"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
      </Grid>
    </Grid>
  </Border>
</Window>
