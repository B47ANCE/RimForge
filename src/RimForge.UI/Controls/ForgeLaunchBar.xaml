<UserControl x:Class="RimForge.UI.Controls.ForgeLaunchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RimForge.UI.Controls"
             x:Name="Root">
  <UserControl.Resources>
    <Style x:Key="LaunchBarProfileActionButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
      <Setter Property="Width" Value="36"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Padding" Value="7"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="LaunchBarProfileActionLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="9"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0,3,0,0"/>
    </Style>
  </UserControl.Resources>
  <Border Background="{DynamicResource Bg1Brush}" BorderBrush="{DynamicResource Bg4Brush}"
          BorderThickness="0,1,0,0" Padding="14,7">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="235"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="ACTIVE PROFILE" Style="{DynamicResource InspectorSectionHeader}"/>
          <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                    DisplayMemberPath="Name" Style="{DynamicResource ProfileComboBox}" MinHeight="30"/>
          <StackPanel Orientation="Horizontal" Margin="2,3,0,0">
            <TextBlock Text="{Binding SelectedProfileModCountText}"
                       FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock Text="  •  " FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock Text="{Binding SelectedProfileStateText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>
        </StackPanel>
        <Button Grid.Column="1" Style="{DynamicResource SecondaryButton}" Content="Profile Management"
                Margin="10,0,0,0" VerticalAlignment="Center" Padding="10,6"
                ToolTip="Open Settings → Profiles" Click="ProfileManagement_Click"/>
      </Grid>

      <!-- Compact profile status: informational by default, with direct actions only when issues exist. -->
      <Border Grid.Column="2" Padding="8,4" CornerRadius="7" Background="Transparent"
              BorderBrush="{DynamicResource Bg4Brush}" BorderThickness="1" VerticalAlignment="Center"
              ToolTip="Current profile analysis health and issue status.">
        <StackPanel>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="8" Height="8" Fill="{Binding ActiveProfileHealthBrush}" Margin="0,0,7,0"/>
            <StackPanel>
              <TextBlock Text="PROFILE HEALTH" FontSize="8" FontWeight="Bold"
                         Foreground="{DynamicResource TextMutedBrush}"/>
              <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                <TextBlock Text="{Binding ActiveProfileHealthText}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{Binding ActiveProfileHealthBrush}"/>
                <TextBlock Text="  ·  " FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                <TextBlock Text="{Binding ActiveProfileIssueStatusText}" FontSize="9" FontWeight="SemiBold"
                           Foreground="{Binding ActiveProfileHealthBrush}"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="15,4,0,0">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasActiveProfileIssues}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <Button Style="{DynamicResource SecondaryButton}" Content="Show" Click="ShowIssues_Click"
                    Padding="7,1" MinHeight="22" FontSize="9" Margin="0,0,4,0"
                    ToolTip="Show issues for the active profile."/>
            <Button Style="{DynamicResource SecondaryButton}" Content="Fix" Click="FixIssues_Click"
                    Padding="7,1" MinHeight="22" FontSize="9"
                    ToolTip="Preview repairs for the active profile."/>
          </StackPanel>
        </StackPanel>
      </Border>

      <StackPanel Grid.Column="4" VerticalAlignment="Center">
        <TextBlock Text="LOAD ORDER" Style="{DynamicResource InspectorSectionHeader}" Margin="2,0,0,3"/>
        <Border Background="{DynamicResource Bg2Brush}" BorderBrush="{DynamicResource Bg4Brush}"
                BorderThickness="1" CornerRadius="9" Padding="6">
          <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="106"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="112"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="32"/>
          </Grid.RowDefinitions>
          <Button Grid.Row="0" Grid.Column="0" Content="Sort"
                  Click="ManualAutoSort_Click" Padding="5,2" FontSize="10">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource ChromePlusSortButton}">
                <Setter Property="IsEnabled" Value="True"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsLoadOrderCanonical}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <Button.ToolTip>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Apply RimForge's canonical load order."/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsLoadOrderCanonical}" Value="True">
                        <Setter Property="Text" Value="Load order already matches RimForge's canonical ordering."/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </Button.ToolTip>
          </Button>
          <Button Grid.Row="0" Grid.Column="2" Style="{DynamicResource SecondaryButton}" Content="Revert Changes"
                  Click="RevertChanges_Click" Padding="5,2" FontSize="10"/>
          <ToggleButton Grid.Row="2" Grid.Column="0" Style="{DynamicResource InstantAutoSortToggle}"
                        IsChecked="{Binding IsInstantAutoSortEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="5,1"
                        ToolTip="When enabled, dropped mods are placed at RimForge's optimized load-order position.">
            <StackPanel>
              <TextBlock Text="Auto-Sort" FontWeight="SemiBold" FontSize="10" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding AutoSortStateText}" FontSize="8" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
          </ToggleButton>
          <Button Grid.Row="2" Grid.Column="2" Style="{DynamicResource DirtySaveButton}" Content="Save Load Order"
                  Click="SaveLoadOrder_Click" IsEnabled="{Binding IsLoadOrderDirty}" Padding="5,2" FontSize="10"
                  ToolTip="Save Active Mods Load Order"/>
          </Grid>
        </Border>
      </StackPanel>

      <StackPanel Grid.Column="6" VerticalAlignment="Center">
        <TextBlock Text="FORGE" Style="{DynamicResource InspectorSectionHeader}" Margin="2,0,0,3"/>
        <StackPanel Orientation="Horizontal">
        <Button Style="{DynamicResource IgniteForgeButton}" Click="Forge_Click" MinHeight="40" Padding="10,5" Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal">
            <local:ForgeIcon Kind="Ignite" IconBrush="{DynamicResource TextPrimaryBrush}" Margin="0,0,6,0"/>
            <TextBlock FontWeight="SemiBold" FontSize="11">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text" Value="Ignite the Forge"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsForgeRunning}" Value="True">
                      <Setter Property="Text" Value="Cancel Forge"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>
        </Button>
        <StackPanel Margin="0,0,8,0">
          <Button x:Name="RefreshButton" Style="{DynamicResource SecondaryButton}" Width="46" Height="42"
                  ClipToBounds="False"
                  ToolTip="Refresh&#x0a;Rescan the installed mod library." Click="Refresh_Click">
            <Grid x:Name="RefreshIconHost"
                  Width="32"
                  Height="32"
                  ClipToBounds="False"
                  RenderTransformOrigin="0.5,0.5">
              <Image Width="20"
                     Height="20"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Source="/RimForge.UI;component/Assets/Icons/Actions/Refresh.png"/>
            </Grid>
          </Button>
          <TextBlock Text="Refresh" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,0"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
        <Button Style="{DynamicResource PrimaryButton}" Click="Launch_Click" MinHeight="40" Padding="10,5">
          <StackPanel Orientation="Horizontal">
            <local:ForgeIcon Kind="Launch" IconBrush="White" Margin="0,0,6,0"/>
            <TextBlock Text="Launch RimWorld" FontSize="11"/>
          </StackPanel>
        </Button>
        </StackPanel>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
