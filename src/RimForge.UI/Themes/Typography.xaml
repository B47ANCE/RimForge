<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <FontFamily x:Key="RimForgeFontFamily">Segoe UI</FontFamily>
  <FontFamily x:Key="RimForgeMonospaceFontFamily">Cascadia Mono, Consolas</FontFamily>

  <Style x:Key="PageTitleText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource RimForgeFontFamily}"/>
    <Setter Property="FontSize" Value="30"/>
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>

  <Style x:Key="SectionTitleText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource RimForgeFontFamily}"/>
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>
</ResourceDictionary>
