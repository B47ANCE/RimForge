<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="Bg0">#1E1F22</Color>
  <Color x:Key="Bg1">#2B2D31</Color>
  <Color x:Key="Bg2">#313338</Color>
  <Color x:Key="Bg3">#383A40</Color>
  <Color x:Key="Bg4">#404249</Color>
  <Color x:Key="NavSelected">#232428</Color>
  <Color x:Key="ActiveSurface">#332F8C28</Color>
  <Color x:Key="PressedSurface">#25272B</Color>
  <Color x:Key="Focus">#4DA3FF</Color>
  <Color x:Key="Disabled">#777B84</Color>
  <Color x:Key="Accent">#D97735</Color>
  <Color x:Key="AccentHover">#EA8B47</Color>
  <Color x:Key="TextPrimary">#F2F3F5</Color>
  <Color x:Key="TextMuted">#B5BAC1</Color>
  <Color x:Key="Information">#4C9AFF</Color>
  <Color x:Key="Success">#23A55A</Color>
  <Color x:Key="Warning">#F0B232</Color>
  <Color x:Key="Danger">#F23F42</Color>
  <SolidColorBrush x:Key="Bg0Brush" Color="{StaticResource Bg0}"/>
  <SolidColorBrush x:Key="Bg1Brush" Color="{StaticResource Bg1}"/>
  <SolidColorBrush x:Key="Bg2Brush" Color="{StaticResource Bg2}"/>
  <SolidColorBrush x:Key="Bg3Brush" Color="{StaticResource Bg3}"/>
  <SolidColorBrush x:Key="Bg4Brush" Color="{StaticResource Bg4}"/>
  <SolidColorBrush x:Key="NavSelectedBrush" Color="{StaticResource NavSelected}"/>
  <SolidColorBrush x:Key="ActiveSurfaceBrush" Color="{StaticResource ActiveSurface}"/>
  <SolidColorBrush x:Key="PressedSurfaceBrush" Color="{StaticResource PressedSurface}"/>
  <SolidColorBrush x:Key="FocusBrush" Color="{StaticResource Focus}"/>
  <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource Disabled}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
  <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
  <SolidColorBrush x:Key="InformationBrush" Color="{StaticResource Information}"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
  <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>

  <!-- Forge-wide native text-selection colors. These override the default Windows blue. -->
  <SolidColorBrush x:Key="ForgeSelectionBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="ForgeInactiveSelectionBrush" Color="#B85F25"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource TextPrimary}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#B85F25"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{StaticResource TextPrimary}"/>
  <!-- Commit 11 visual-system semantic aliases. -->
  <SolidColorBrush x:Key="VisualSurfaceBaseBrush" Color="{StaticResource Bg0}"/>
  <SolidColorBrush x:Key="VisualSurfaceRaisedBrush" Color="{StaticResource Bg1}"/>
  <SolidColorBrush x:Key="VisualSurfaceCardBrush" Color="{StaticResource Bg2}"/>
  <SolidColorBrush x:Key="VisualSurfaceHoverBrush" Color="{StaticResource Bg3}"/>
  <SolidColorBrush x:Key="VisualBorderBrush" Color="{StaticResource Bg4}"/>
  <SolidColorBrush x:Key="VisualActiveMarkerBrush" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="VisualActiveSurfaceBrush" Color="{StaticResource ActiveSurface}"/>
  <SolidColorBrush x:Key="VisualFocusBrush" Color="{StaticResource Focus}"/>
  <CornerRadius x:Key="VisualControlCornerRadius">7</CornerRadius>
  <CornerRadius x:Key="VisualCardCornerRadius">10</CornerRadius>
  <Thickness x:Key="VisualControlPadding">12,8</Thickness>
  <Thickness x:Key="VisualActiveLeftMarkerThickness">3,0,0,0</Thickness>
  <Thickness x:Key="VisualActiveBottomMarkerThickness">0,0,0,3</Thickness>
  <sys:Double x:Key="VisualControlHeight" xmlns:sys="clr-namespace:System;assembly=mscorlib">38</sys:Double>
  <sys:Double x:Key="VisualDisabledOpacity" xmlns:sys="clr-namespace:System;assembly=mscorlib">0.45</sys:Double>
</ResourceDictionary>
